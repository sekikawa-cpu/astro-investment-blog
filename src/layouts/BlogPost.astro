---
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import type { CollectionEntry } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, author, pillar, category, tags, heroImage, noindex } = Astro.props;

const currentPath = Astro.url.pathname;
const fullUrl = `https://tech-wealth-mind.com${currentPath}`;
const ogImageUrl = heroImage
  ? `https://tech-wealth-mind.com${heroImage}`
  : 'https://tech-wealth-mind.com/images/profile.png';

const schemaData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "image": heroImage ? `https://tech-wealth-mind.com${heroImage}` : undefined,
  "datePublished": pubDate.toISOString(),
  "dateModified": updatedDate ? updatedDate.toISOString() : pubDate.toISOString(),
  "author": {
    "@type": "Person",
    "name": author,
    "url": "https://tech-wealth-mind.com/profile"
  },
  "publisher": {
    "@type": "Organization",
    "name": "会社員の生活日記",
    "url": "https://tech-wealth-mind.com"
  },
  "url": fullUrl,
  "articleSection": category,
  "keywords": tags.join(", ")
};
const CATEGORY_URLS: Record<string, string> = {
  'AIツール':     '/category/ai-dx/',
  'AI最新情報':   '/category/ai-dx/',
  '資格・学習':   '/category/shikaku/',
  'DX・業務改善': '/category/shigoto/',
  '書籍レビュー': '/category/shigoto/',
  'コラム': '/',
};
const categoryUrl = CATEGORY_URLS[category] ?? '/';
const breadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://tech-wealth-mind.com/" },
    { "@type": "ListItem", "position": 2, "name": category, "item": `https://tech-wealth-mind.com${categoryUrl}` },
    { "@type": "ListItem", "position": 3, "name": title, "item": fullUrl }
  ]
};
---
<BaseLayout title={title} description={description} noindex={noindex} ogImage={ogImageUrl}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />
  <article class="article">
    <div class="container-narrow">
      <header class="article-header">
        <div class="article-meta-top">
          <span class="badge">{category}</span>
        </div>
        <h1 class="article-title">{title}</h1>
        <p class="article-lead">{description}</p>
        <div class="article-meta">
          <span class="meta-author">{author}</span>
          <span class="meta-sep">·</span>
          <FormattedDate date={pubDate} />
          {updatedDate && (
            <>
              <span class="meta-sep">·</span>
              <span class="meta-updated">更新: <FormattedDate date={updatedDate} /></span>
            </>
          )}
        </div>
      </header>

      {category === '生きづらさと回復' && (
        <div class="content-warning">
          <div class="content-warning-header">
            <span>📢</span>
            <strong>コンテンツ警告</strong>
          </div>
          <p class="content-warning-body">※本記事には家庭内の困難な経験に関する記述が含まれます。回復プロセスを共有する目的で執筆しています。</p>
        </div>
      )}

      {heroImage && (
        <div class="article-hero">
          <img src={heroImage} alt={title} />
        </div>
      )}

      <div class="prose article-content">
        <slot />
      </div>

      {tags.length > 0 && (
        <div class="article-tags">
          {tags.map((tag) => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
      )}


      <div class="back-link">
        <a id="article-back-btn" href="/search"
           class="inline-block bg-slate-800 hover:bg-slate-700 text-white font-bold px-8 py-3 rounded-full transition-colors text-sm">
          📰 記事一覧に戻る
        </a>
      </div>
    </div>
  </article>
</BaseLayout>

<style is:global>
  .code-block-wrapper {
    position: relative;
    margin: 1.5rem 0.75rem 2rem;
    border-radius: 0.5rem;
    overflow: hidden;
    background: #000;
  }
  .code-block-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.55rem 0.85rem;
    background: #000;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  .code-block-lang {
    font-size: 0.78rem;
    font-weight: 600;
    color: #e2e8f0;
    font-family: 'Inter', ui-sans-serif, sans-serif;
    letter-spacing: 0.02em;
    text-transform: capitalize;
    user-select: none;
  }
  .code-block-actions {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .code-action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    background: transparent;
    border: none;
    border-radius: 4px;
    color: #94a3b8;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    padding: 0;
  }
  .code-action-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #e2e8f0;
  }
  .code-action-btn.copied {
    color: #4ade80;
  }
  .code-block-wrapper pre {
    margin: 0;
    border-radius: 0;
    padding: 1rem 1.25rem 1.5rem !important;
  }
</style>

<script>
  function setupCopyButtons() {
    document.querySelectorAll('.article-content pre').forEach((pre) => {
      if (pre.parentElement?.classList.contains('code-block-wrapper')) return;

      const codeEl = pre.querySelector('code');
      const lang = pre.getAttribute('data-language') || 'code';

      const wrapper = document.createElement('div');
      wrapper.className = 'code-block-wrapper';
      pre.parentNode!.insertBefore(wrapper, pre);
      wrapper.appendChild(pre);

      const header = document.createElement('div');
      header.className = 'code-block-header';
      header.innerHTML = `
        <span class="code-block-lang">${lang}</span>
        <div class="code-block-actions">
          <button class="code-action-btn download-btn" aria-label="ダウンロード">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
          </button>
          <button class="code-action-btn copy-btn" aria-label="コードをコピー">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
          </button>
        </div>
      `;
      wrapper.insertBefore(header, pre);

      const downloadBtn = header.querySelector('.download-btn')!;
      downloadBtn.addEventListener('click', () => {
        const text = (codeEl ?? pre).innerText;
        const blob = new Blob([text], { type: 'text/plain' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `code.${lang}`;
        a.click();
        URL.revokeObjectURL(url);
      });

      const copyBtn = header.querySelector('.copy-btn')!;
      copyBtn.addEventListener('click', async () => {
        const text = (codeEl ?? pre).innerText;
        try {
          await navigator.clipboard.writeText(text);
          copyBtn.classList.add('copied');
          setTimeout(() => copyBtn.classList.remove('copied'), 2000);
        } catch {
          /* clipboard API 未対応環境は無視 */
        }
      });
    });
  }

  setupCopyButtons();
  document.addEventListener('astro:page-load', setupCopyButtons);
</script>

<script>
  // 記事下部の戻るボタン：前ページに応じて文脈切り替え
  (function() {
    const btn = document.getElementById('article-back-btn');
    if (!btn) return;
    const ref = document.referrer;
    const origin = location.origin;
    const refPath = (ref && ref.startsWith(origin))
      ? ref.slice(origin.length).split('?')[0]
      : '';
    if (refPath === '/' || refPath === '') {
      // トップページ経由 or 直接アクセス
      if (refPath === '/') {
        btn.textContent = '🏠 トップページに戻る';
        (btn as HTMLAnchorElement).href = '/';
      }
      // 直接アクセス（refPath===''）はデフォルトの「📰 記事一覧に戻る」のまま
    } else {
      btn.textContent = '📰 記事一覧に戻る';
      (btn as HTMLAnchorElement).href = ref;
    }
  })();
</script>

<style>
  .article { padding: 3rem 0 1rem; }
  .article-header {
    text-align: left;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }
  .article-meta-top { margin-bottom: 1rem; }
  .article-title {
    font-size: 2.1rem;
    line-height: 1.4;
    margin: 0 0 1rem;
    color: var(--color-primary-900);
  }
  .article-lead {
    font-size: 1.08rem;
    color: var(--color-muted);
    line-height: 1.75;
    margin: 0 0 1.5rem;
  }
  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.9rem;
    color: var(--color-muted);
    flex-wrap: wrap;
  }
  .meta-author { color: var(--color-primary-800); font-weight: 600; }
  .meta-sep { color: var(--color-border); }
  .article-hero { margin: 0 0 2.5rem; }
  .article-hero img {
    width: 100%;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }
  .article-content { margin-bottom: 2.5rem; }
  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 2rem 0;
  }
  .tag {
    background: var(--color-bg-soft);
    color: var(--color-primary-700);
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius);
    font-size: 0.85rem;
    border: 1px solid var(--color-border);
  }
  .disclaimer {
    margin: 2.5rem 0;
    padding: 1.25rem;
    background: var(--color-bg-soft);
    border-left: 3px solid var(--color-primary-500);
    border-radius: 0 var(--radius) var(--radius) 0;
    font-size: 0.88rem;
    line-height: 1.7;
    color: var(--color-muted);
  }
  .disclaimer strong { color: var(--color-primary-800); }
  .disclaimer-prominent {
    background: linear-gradient(135deg, #fff1f2 0%, #ffe4e6 100%);
    border: 2px solid #f87171;
    border-left: 5px solid #dc2626;
    border-radius: 0 0.5rem 0.5rem 0;
    padding: 1.25rem 1.5rem;
    margin: 2rem 0;
  }
  .disclaimer-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    font-weight: 700;
    color: #991b1b;
    font-size: 0.95rem;
  }
  .disclaimer-icon {
    font-size: 1.2rem;
  }
  .disclaimer-content {
    color: #7f1d1d;
    margin: 0;
    line-height: 1.65;
    font-size: 0.88rem;
  }
  .disclaimer-link {
    color: #991b1b;
    text-decoration: underline;
  }
  .disclaimer-link:hover {
    color: #7f1d1d;
  }
  .content-warning {
    margin: 2rem 0;
    padding: 1.25rem 1.5rem;
    background: #f0fdf4;
    border: 1px solid #86efac;
    border-left: 4px solid #22c55e;
    border-radius: 0 0.5rem 0.5rem 0;
  }
  .content-warning-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    color: #15803d;
    margin-bottom: 0.6rem;
    font-size: 0.95rem;
  }
  .content-warning-body {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.7;
    color: #166534;
  }
  .back-link {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.95rem;
    text-align: center;
  }
  @media (max-width: 640px) {
    .article-title { font-size: 1.65rem; }
  }
</style>
