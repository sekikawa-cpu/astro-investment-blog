---
// BaseLayout.astro - 堅実な動作を目指した統合レイアウト
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import '../styles/global.css';

const googleAnalyticsId = import.meta.env.PUBLIC_GOOGLE_ANALYTICS_ID || 'G-2F8G5290KT';
console.log('GA ID:', googleAnalyticsId, 'env:', import.meta.env.PUBLIC_GOOGLE_ANALYTICS_ID);

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  ogImage?: string;
}

const { title, description = SITE_DESCRIPTION, noindex = false, ogImage } = Astro.props;
const defaultOgImage = 'https://tech-wealth-mind.com/images/profile.png';
const ogImageUrl = ogImage || defaultOgImage;
const pageTitle = title ? `${title} | ${SITE_TITLE}` : SITE_TITLE;
// 実際のサーバーは末尾スラッシュありで配信するため、canonicalも合わせる
const rawPath = Astro.url.pathname;
const normalizedPath = rawPath === '/' ? '/' : (rawPath.endsWith('/') ? rawPath : rawPath + '/');
const canonicalURL = new URL(normalizedPath, Astro.site);

const categoryLinks = [
  { name: '📊 投資', href: '/category/toshi/' },
  { name: '🤖 AI/DX', href: '/category/business-ai-dx/' },
  { name: '🧠 心理学', href: '/category/shinrigaku/' },
  { name: '✨ 初めての方へ', href: '/for-beginners/' },
];
const pageLinks = [
  { name: 'プロフィール', href: '/about/' },
  { name: 'お問い合わせ', href: '/contact/' },
  { name: 'プライバシーポリシー', href: '/privacy/' },
  { name: '免責事項', href: '/disclaimer/' },
  { name: 'サイトマップ', href: '/sitemap/' },
];
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- OGP / Twitter Card -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="会社員の生活日記" />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet" />
    <!-- DEBUG: googleAnalyticsId={googleAnalyticsId} -->
    <!-- Google Analytics -->
    {googleAnalyticsId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`}></script>
        <script define:vars={{ googleAnalyticsId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', googleAnalyticsId);
        </script>
      </>
    )}
    <!-- Google AdSense -->
    <meta name="google-adsense-account" content="ca-pub-7499855875738477">
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7499855875738477"
     crossorigin="anonymous"></script>
  </head>
  <body>
    <header class="site-header">
      <div class="header-container">
        <!-- ロゴ -->
        <a href="/" class="logo">
          会社員の生活日記<span class="logo-dot">.</span>
        </a>

        <!-- デスクトップ：カテゴリナビ -->
        <nav class="cat-nav">
          {categoryLinks.map((item) => (
            <a href={item.href} class={`cat-nav-link${item.href === '/for-beginners/' ? ' cat-nav-link--highlight' : ''}`}>{item.name}</a>
          ))}
        </nav>

        <div class="menu-wrapper">
          <!-- デスクトップ：ページリンク直接表示 -->
          <div class="page-links">
            {pageLinks.map((item) => (
              <a href={item.href} class="page-link">{item.name}</a>
            ))}
          </div>

          <!-- モバイル：三本線ボタン -->
          <button id="menu-toggle" class="menu-button" aria-label="メニュー">
            <svg id="icon-hamburger" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
            <svg id="icon-close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>

          <!-- ドロップダウンメニュー（モバイル用・全リンク含む） -->
          <nav id="nav-menu" class="nav-menu">
            <div class="nav-section-label">カテゴリ</div>
            <ul class="nav-list">
              <li><a href="/" class="nav-link">🏠 ホーム</a></li>
              {categoryLinks.map((item) => (
                <li><a href={item.href} class="nav-link">{item.name}</a></li>
              ))}
            </ul>
            <div class="nav-divider"></div>
            <div class="nav-section-label">サイト情報</div>
            <ul class="nav-list">
              {pageLinks.map((item) => (
                <li><a href={item.href} class="nav-link">{item.name}</a></li>
              ))}
            </ul>
          </nav>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <Footer />

    <style is:global>
      :root {
        --header-height: 70px;
        --primary-blue: #1a365d;
        --accent-blue: #3182ce;
      }

      body {
        margin: 0;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        font-family: 'Inter', 'Noto Sans JP', sans-serif;
      }

      main { flex: 1; }

      .site-header {
        height: var(--header-height);
        background: #ffffff;
        border-bottom: 1px solid #e2e8f0;
        position: sticky;
        top: 0;
        z-index: 1000;
        display: flex;
        align-items: center;
      }

      .header-container {
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .logo {
        text-decoration: none;
        font-size: 1.1rem;
        font-weight: 800;
        color: var(--primary-blue);
        white-space: nowrap;
        flex-shrink: 0;
      }
      .logo-dot { color: var(--accent-blue); }

      /* デスクトップ カテゴリナビ */
      .cat-nav {
        display: none;
        align-items: center;
        gap: 0.15rem;
        flex: 1;
        padding: 0 0.75rem;
      }
      @media (min-width: 900px) { .cat-nav { display: flex; } }

      .cat-nav-link {
        padding: 0.35rem 0.6rem;
        border-radius: 6px;
        text-decoration: none;
        font-size: 0.82rem;
        font-weight: 600;
        color: #2d3748;
        white-space: nowrap;
        transition: background 0.15s, color 0.15s;
      }
      .cat-nav-link:hover { background: #ebf8ff; color: var(--accent-blue); }
      .cat-nav-link--highlight {
        background: #ebf8ff;
        color: var(--accent-blue);
        border: 1px solid #bfdbfe;
      }

      .menu-wrapper {
        position: relative;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-shrink: 0;
      }

      /* デスクトップ ページリンク */
      .page-links {
        display: none;
        align-items: center;
        gap: 0.1rem;
      }
      @media (min-width: 900px) { .page-links { display: flex; } }

      .page-link {
        padding: 0.3rem 0.5rem;
        text-decoration: none;
        font-size: 0.78rem;
        color: #4a5568;
        font-weight: 500;
        border-radius: 4px;
        white-space: nowrap;
        transition: color 0.15s, background 0.15s;
      }
      .page-link:hover { color: var(--accent-blue); background: #f7fafc; }

      /* モバイル ハンバーガー */
      .menu-button {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        padding: 8px;
        cursor: pointer;
        color: var(--primary-blue);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s;
      }
      @media (min-width: 900px) { .menu-button { display: none; } }
      .menu-button:hover { background: #edf2f7; }

      .hidden { display: none; }

      /* ドロップダウン（モバイル用） */
      .nav-menu {
        position: absolute;
        top: calc(100% + 12px);
        right: 0;
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        min-width: 240px;
        opacity: 0;
        visibility: hidden;
        transform: translateY(-10px);
        transition: all 0.2s ease;
        z-index: 1001;
      }
      .nav-menu.is-active {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
      }
      .nav-section-label {
        padding: 8px 16px 4px;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #94a3b8;
      }
      .nav-divider { height: 1px; background: #e2e8f0; margin: 4px 0; }
      .nav-list { list-style: none; padding: 4px 0; margin: 0; }
      .nav-link {
        display: block;
        padding: 10px 20px;
        text-decoration: none;
        color: #2d3748;
        font-size: 0.9rem;
        font-weight: 500;
      }
      .nav-link:hover { background-color: #f7fafc; color: var(--accent-blue); }
    </style>

    <script>
      function setupMenu() {
        const toggle = document.getElementById('menu-toggle');
        const menu = document.getElementById('nav-menu');
        const iconHam = document.getElementById('icon-hamburger');
        const iconClose = document.getElementById('icon-close');

        if (!toggle || !menu) return;

        toggle.addEventListener('click', (e) => {
          e.stopPropagation();
          const isActive = menu.classList.toggle('is-active');
          iconHam?.classList.toggle('hidden');
          iconClose?.classList.toggle('hidden');
        });

        // 外側をクリックしたら閉じる
        document.addEventListener('click', (e) => {
          if (!menu.contains(e.target as Node) && !toggle.contains(e.target as Node)) {
            menu.classList.remove('is-active');
            iconHam?.classList.remove('hidden');
            iconClose?.classList.add('hidden');
          }
        });
      }

      // 初回実行
      setupMenu();
      // Astroの画面遷移（ViewTransitions等）を使用している場合にも対応
      document.addEventListener('astro:page-load', setupMenu);
    </script>
  </body>
</html>
