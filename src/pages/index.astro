---
import { getCollection } from 'astro:content';

const googleAnalyticsId = import.meta.env.PUBLIC_GOOGLE_ANALYTICS_ID || 'G-2F8G5290KT';

const allPosts = await getCollection('blog');
const posts = allPosts.filter(p => !p.data.noindex);
posts.sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

// カテゴリー別記事数
const categoryCount: Record<string, number> = {};
posts.forEach(p => {
  const cat = p.data.category || 'マーケット分析';
  categoryCount[cat] = (categoryCount[cat] || 0) + 1;
});

// 人気記事（最新5本をPVの代わりに使用）
const popularPosts = posts.slice(0, 5);

// 柱別記事（各最大4件）
const PILLAR_KEYS = ['投資', 'ビジネス・AI・DX', '心理学'] as const;
const postsByPillar: Record<string, typeof posts> = {};
PILLAR_KEYS.forEach(p => {
  postsByPillar[p] = posts.filter(post => (post.data.pillar ?? '投資') === p);
});

// 柱カラー定義
const PILLAR_BORDER: Record<string, string> = {
  '投資':   'border-blue-500',
  'ビジネス・AI・DX': 'border-purple-500',
  '心理学': 'border-teal-500',
};
const PILLAR_TEXT: Record<string, string> = {
  '投資':   'text-blue-600',
  'ビジネス・AI・DX': 'text-purple-600',
  '心理学': 'text-teal-600',
};
const PILLAR_BG: Record<string, string> = {
  '投資':   'bg-blue-100 text-blue-700',
  'ビジネス・AI・DX': 'bg-purple-100 text-purple-700',
  '心理学': 'bg-teal-100 text-teal-700',
};

// 3本柱のカテゴリー定義
const PILLAR_CATEGORIES: Record<string, string[]> = {
  '投資':   ['マーケット分析', '資産運用', '投資戦略', '経済ニュース', '初心者ガイド', 'キーワード解説', 'コラム'],
  'ビジネス・AI・DX': ['AI最新情報', 'DX・業務改善', '資格・学習', '書籍レビュー'],
  '心理学': ['心理学・メンタル', '生きづらさと回復'],
};
const PILLAR_ICONS: Record<string, string> = {
  '投資':   '📊',
  'ビジネス・AI・DX': '🤖',
  '心理学': '🧠',
};
const PILLAR_COLORS: Record<string, string> = {
  '投資':   'text-blue-600',
  'ビジネス・AI・DX': 'text-purple-600',
  '心理学': 'text-teal-600',
};

