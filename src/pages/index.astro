---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

// カテゴリー別記事数
const categoryCount: Record<string, number> = {};
posts.forEach(p => {
  const cat = p.data.category || 'マーケット分析';
  categoryCount[cat] = (categoryCount[cat] || 0) + 1;
});

// 人気記事（最新5本をPVの代わりに使用）
const popularPosts = posts.slice(0, 5);

// 3本柱のカテゴリー定義
const PILLAR_CATEGORIES: Record<string, string[]> = {
  '投資':   ['マーケット分析', '資産運用', '投資戦略', '経済ニュース', '初心者ガイド', 'キーワード解説', 'コラム'],
  'AI・DX': ['AI最新情報', 'DX・業務改善', '資格・学習'],
  '心理学': ['心理学・メンタル', '生きづらさと回復', '書籍レビュー'],
};
const PILLAR_ICONS: Record<string, string> = {
  '投資':   '📊',
  'AI・DX': '🤖',
  '心理学': '🧠',
};
const PILLAR_COLORS: Record<string, string> = {
  '投資':   'text-blue-600',
  'AI・DX': 'text-purple-600',
  '心理学': 'text-teal-600',
};

