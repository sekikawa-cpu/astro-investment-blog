---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

// カテゴリー別記事数
const categoryCount: Record<string, number> = {};
posts.forEach(p => {
  const cat = p.data.category || 'マーケット分析';
  categoryCount[cat] = (categoryCount[cat] || 0) + 1;
});

// 人気記事（最新5本をPVの代わりに使用）
const popularPosts = posts.slice(0, 5);
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>配当＆優待ナビ | 高配当株・株主優待で不労所得を育てる</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="google-site-verification" content="A8tOtO8MGTE81uwVZVGSbnvRT2F583xupmBPJzmTgKc" />
    <meta name="description" content="高配当ETFや株主優待銘柄の最新動向を毎日お届け。新NISAや配当投資で不労所得を育てるためのヒントをわかりやすく解説します。">
    <link rel="canonical" href="https://astro-investment-blog-1gwd.vercel.app/">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://astro-investment-blog-1gwd.vercel.app/">
    <meta property="og:title" content="配当＆優待ナビ | 高配当株・株主優待で不労所得を育てる">
    <meta property="og:description" content="高配当ETFや株主優待銘柄の最新動向を毎日お届け。">
    <link rel="stylesheet" href="/styles/global.css">
  </head>

  <body>
    <main>
      <h1>最新の投資レポート</h1>
      <ul>
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.slug}/`}>
              {post.data.title}
            </a>
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('ja-JP')}
            </time>
          </li>
        ))}
      </ul>
    </main>

    <script is:inline>
      // ── クライアントサイド・スクリプト ──
      (function() {
        const ICONS = {
          ship: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="card-icon"><path d="M2 21c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1 .6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M19.38 20L21 7l-9.5 4-9.5-4 1.62 13"/><path d="M12 12v9"/></svg>`,
          bank: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="card-icon"><rect x="2" y="10" width="20" height="12" rx="2"/><path d="M12 22V10"/><path d="M2 10l10-8 10 8"/><path d="M6 22V10"/><path d="M18 22V10"/></svg>`,
          nisa: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="card-icon"><path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/><rect x="2" y="2" width="20" height="20" rx="1"/></svg>`,
        };

        // タイトルキーワードでアイコンを切り替えるマップ
        const KEYWORD_MAP = [
          [['海運','郵船','船'], 'ship'],
          [['銀行','メガバンク','金利','日銀'], 'bank'],
          [['NISA','nisa','非課税','積立'], 'nisa']
        ]; // ← 配列を閉じる (修正箇所)

        // 背景に透かしアイコンを入れる等の処理があればここに記述
      })(); // ← 即時関数を閉じる (修正箇所)

      // ── ドロワー開閉 ──
      function openDrawer() {
        const drawer = document.getElementById('drawer');
        const overlay = document.getElementById('drawerOverlay');
        if (drawer) drawer.classList.add('open');
        if (overlay) overlay.classList.add('open');
        document.body.style.overflow = 'hidden';
      }

      function closeDrawer() {
        const drawer = document.getElementById('drawer');
        const overlay = document.getElementById('drawerOverlay');
        if (drawer) drawer.classList.remove('open');
        if (overlay) overlay.classList.remove('open');
        document.body.style.overflow = '';
      }

      // モバイル検索トグル
      function toggleMobileSearch() {
        const bar = document.getElementById('mobileSearchBar');
        if (bar) {
          bar.classList.toggle('hidden');
          if (!bar.classList.contains('hidden')) {
            const input = document.getElementById('mobileSearchInput');
            if (input) input.focus();
          }
        }
      }

      // 検索実行
      function doSearch(e) {
        e.preventDefault();
        const inputs = ['headerSearchInput', 'sidebarSearchInput', 'drawerSearchInput', 'mobileSearchInput'];
        let q = '';
        for (const id of inputs) {
          const el = document.getElementById(id);
          if (el && el.value.trim()) {
            q = el.value.trim();
            break;
          }
        }
        if (!q) return;
        window.location.href = `/search?q=${encodeURIComponent(q)}`;
      }

      // グローバルに公開
      window.openDrawer = openDrawer;
      window.closeDrawer = closeDrawer;
      window.toggleMobileSearch = toggleMobileSearch;
      window.doSearch = doSearch;
    </script>
  </body>
</html>
