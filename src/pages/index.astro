---
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>配当＆優待ナビ | 高配当株・株主優待で不労所得を育てる</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="google-site-verification" content="A8tOtO8MGTE81uwVZVGSbnvRT2F583xupmBPJzmTgKc" />
    <meta name="description" content="高配当ETFや株主優待銘柄の最新動向を毎日お届け。新NISAや配当投資で不労所得を育てるためのヒントをわかりやすく解説します。">
    <style>
      /* 関川さんの元のスタイルをすべて維持 */
      .drawer-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 40; }
      .drawer-overlay.open { display: block; }
      .drawer { position: fixed; top: 0; right: -320px; width: 300px; height: 100vh; background: #fff; z-index: 50; transition: right 0.3s ease; overflow-y: auto; box-shadow: -4px 0 20px rgba(0,0,0,0.15); }
      .drawer.open { right: 0; }
      .post-card { position: relative; overflow: hidden; }
      .post-card-wm { position: absolute; inset: 0; width: 100%; height: 100%; opacity: 0.065; pointer-events: none; }
      .post-card-wm svg { width: 100%; height: 100%; display: block; }
      .post-card-content { position: relative; z-index: 1; }
      .sidebar-widget { background: #fff; border-radius: 0.5rem; border: 1px solid #e2e8f0; overflow: hidden; margin-bottom: 1.5rem; }
      .sidebar-widget-title { background: #1e293b; color: #fff; padding: 0.6rem 1rem; font-weight: 700; font-size: 0.9rem; }
      .sidebar-widget-body { padding: 0.75rem 1rem; }
      .popular-rank { min-width: 1.6rem; height: 1.6rem; background: #3b82f6; color: #fff; border-radius: 0.25rem; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.8rem; flex-shrink: 0; }
      .rank-1 { background: #f59e0b; } .rank-2 { background: #94a3b8; } .rank-3 { background: #b45309; }
      .cat-badge { background: #dbeafe; color: #1d4ed8; font-size: 0.75rem; font-weight: 700; padding: 0.1rem 0.5rem; border-radius: 9999px; }
    </style>
  </head>

  <body class="bg-slate-50 text-slate-800 font-sans min-h-screen flex flex-col">
    <div class="drawer-overlay" id="drawerOverlay" onclick="closeDrawer()"></div>

    <div class="drawer" id="drawer">
      <div class="flex items-center justify-between px-5 py-4 bg-slate-900 text-white">
        <span class="font-bold text-lg">メニュー</span>
        <button onclick="closeDrawer()" class="text-white">✕ CLOSE</button>
      </div>
      <div class="px-5 py-4">
        <form onsubmit="doSearch(event)" class="flex">
          <input id="drawerSearchInput" type="text" class="flex-1 border px-3 py-2 text-sm rounded-l" placeholder="検索...">
          <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded-r font-bold">検索</button>
        </form>
      </div>
      </div>

    <header class="bg-slate-900 text-white shadow-md py-3 sticky top-0 z-30">
      <div class="max-w-6xl mx-auto px-4 flex items-center justify-between">
        <a href="/" class="text-xl font-bold">配当＆優待ナビ 💸</a>
        <button onclick="openDrawer()" class="md:hidden text-white font-bold">MENU</button>
      </div>
    </header>

    <main class="flex-grow max-w-6xl mx-auto px-4 py-8 w-full">
      <div class="flex flex-col lg:flex-row gap-8">
        <div class="flex-1">
          <h2 class="text-xl font-bold border-b-2 border-blue-500 pb-2 mb-5">📋 最新の記事</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            {posts.map((post) => (
              <a href={`/blog/${post.slug}`} class="post-card block bg-white rounded-xl shadow-sm border p-5 transition-all hover:border-blue-400">
                <div class="post-card-content">
                  <span class="text-xs bg-blue-100 text-blue-700 font-bold px-2 py-0.5 rounded-full">{post.data.category}</span>
                  <h3 class="text-base font-bold mt-2">{post.data.title}</h3>
                  <p class="text-slate-500 text-xs mt-2 line-clamp-2">{post.data.description}</p>
                </div>
              </a>
            ))}
          </div>
        </div>

        <aside class="lg:w-72">
          <div class="sidebar-widget">
            <div class="sidebar-widget-title">📂 カテゴリー</div>
            <div class="sidebar-widget-body">
              {Object.entries(categoryCount).map(([cat, count]) => (
                <a href={`/search?q=${cat}`} class="flex justify-between py-2 border-bottom text-sm hover:text-blue-600">
                  <span># {cat}</span> <span class="cat-badge">{count}</span>
                </a>
              ))}
            </div>
          </div>
        </aside>
      </div>
    </main>

    <script is:inline>
      (function() {
        const WM = {
          'マーケット分析': `<svg viewBox="0 0 320 170" xmlns="http://www.w3.org/2000/svg">...</svg>`,
          '投資戦略': `<svg viewBox="0 0 320 170" xmlns="http://www.w3.org/2000/svg">...</svg>`,
          // 他のSVGデータ...
        };

        const KEYWORD_MAP = [
          [['海運','郵船','船'], 'ship'],
          [['銀行','メガバンク','金利','日銀'], 'bank'],
          [['NISA','nisa','非課税','積立'], 'nisa']
        ]; // ← ここを閉じました

      })(); // ← 即時関数を閉じました

      function openDrawer() {
        document.getElementById('drawer').classList.add('open');
        document.getElementById('drawerOverlay').classList.add('open');
      }
      function closeDrawer() {
        document.getElementById('drawer').classList.remove('open');
        document.getElementById('drawerOverlay').classList.remove('open');
      }
      function doSearch(e) {
        e.preventDefault();
        const q = document.getElementById('drawerSearchInput').value;
        if (q) window.location.href = `/search?q=${encodeURIComponent(q)}`;
      }
    </script>
  </body>
</html>
