        opacity: 0.1; /* 0.065から少し濃くして見やすく調整 */
        pointer-events: none;
      }
      .post-card-wm svg { width: 100%; height: 100%; display: block; }
      .post-card-content { position: relative; z-index: 10; }

      /* サイドバーウィジェット */
      .sidebar-widget {
        background: #fff;
        border-radius: 0.5rem;
        border: 1px solid #e2e8f0;
        overflow: hidden;
        margin-bottom: 1.5rem;
      }
      .sidebar-widget-title {
        background: #1e293b;
        color: #fff;
        padding: 0.6rem 1rem;
        font-weight: 700;
        font-size: 0.9rem;
      }
      .sidebar-widget-body { padding: 0.75rem 1rem; }
      /* 人気記事 */
      .popular-item {
        display: flex; align-items: flex-start;
        gap: 0.75rem; padding: 0.6rem 0;
        border-bottom: 1px solid #f1f5f9;
        text-decoration: none; color: inherit;
      }
      .popular-item:last-child { border-bottom: none; }
      .popular-item:hover .popular-title { color: #2563eb; }
      .popular-rank {
        min-width: 1.6rem; height: 1.6rem;
        background: #3b82f6; color: #fff;
        border-radius: 0.25rem;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 0.8rem;
        flex-shrink: 0;
      }
      .popular-rank.rank-1 { background: #f59e0b; }
      .popular-rank.rank-2 { background: #94a3b8; }
      .popular-rank.rank-3 { background: #b45309; }
      .popular-title {
        font-size: 0.82rem; line-height: 1.4;
        color: #334155; font-weight: 500;
        transition: color 0.15s;
      }
      /* カテゴリー */
      .cat-item {
        display: flex; justify-content: space-between; align-items: center;
        padding: 0.5rem 0;
        border-bottom: 1px solid #f1f5f9;
        text-decoration: none; color: #334155;
        font-size: 0.875rem;
        transition: color 0.15s;
      }
      .cat-item:last-child { border-bottom: none; }
      .cat-item:hover { color: #2563eb; }
      .cat-badge {
        background: #dbeafe; color: #1d4ed8;
        font-size: 0.75rem; font-weight: 700;
        padding: 0.1rem 0.5rem; border-radius: 9999px;
      }
      /* ドロワー内カテゴリー */
      .drawer-cat-item {
        display: flex; justify-content: space-between;
        padding: 0.75rem 1.5rem;
        border-bottom: 1px solid #f1f5f9;
        text-decoration: none; color: #1e293b;
        font-size: 0.9rem; font-weight: 500;
        transition: background 0.15s;
      }
      .drawer-cat-item:hover { background: #eff6ff; color: #2563eb; }
    </style>
  </head>

  <body class="bg-slate-50 text-slate-800 font-sans min-h-screen flex flex-col">

    <!-- ドロワーオーバーレイ -->
    <div class="drawer-overlay" id="drawerOverlay" onclick="closeDrawer()"></div>

    <!-- ドロワーメニュー -->
    <div class="drawer" id="drawer">
      <div class="flex items-center justify-between px-5 py-4 bg-slate-900 text-white">
        <span class="font-bold text-lg">メニュー</span>
        <button onclick="closeDrawer()" class="text-white hover:text-blue-300 font-bold text-lg">
          ✕ CLOSE
        </button>
      </div>

      <!-- ドロワー内検索 -->
      <div class="px-5 py-4 border-b border-slate-100">
        <form onsubmit="doSearch(event)" class="flex gap-0">
          <input id="drawerSearchInput" type="text" placeholder="キーワードを入力"
            class="search-input flex-1 border border-slate-300 rounded-l px-3 py-2 text-sm focus:outline-none" />
          <button type="submit"
            class="bg-blue-600 text-white px-4 py-2 rounded-r hover:bg-blue-700 text-sm font-bold">
            検索
          </button>
        </form>
      </div>

      <!-- カテゴリーツリー -->
      {PILLAR_KEYS.map(pillar => {
        const cats = PILLAR_CATEGORIES[pillar];
        const total = cats.reduce((s, c) => s + (categoryCount[c] || 0), 0);
        return (
          <>
            <a href={`/search?q=${encodeURIComponent(pillar)}`}
              class={`flex items-center justify-between px-5 py-2.5 bg-slate-50 font-bold text-sm ${PILLAR_TEXT[pillar]}`}>
              <span>{PILLAR_ICONS[pillar]} {pillar}</span>
              {total > 0 && <span class="cat-badge">{total}</span>}
            </a>
            <div class="ml-5 border-l-2 border-slate-200">
              {cats.filter(cat => (categoryCount[cat] || 0) > 0).map(cat => (
                <a href={`/search?q=${encodeURIComponent(cat)}`}
                  class="flex items-center justify-between pl-3 pr-5 py-2 border-b border-slate-50 text-sm text-slate-700 hover:bg-blue-50 hover:text-blue-600">
                  <span>{cat}</span>
                  <span class="cat-badge">{categoryCount[cat]}</span>
                </a>
              ))}
            </div>
          </>
        );
      })}

      <!-- サイト情報 -->
      <div class="px-5 py-3 mt-2 text-xs font-bold text-slate-500 uppercase tracking-wider bg-slate-50">このサイトについて</div>
      <a href="/about/" class="drawer-cat-item">○ 運営者について</a>
      <a href="/privacy/" class="drawer-cat-item">○ プライバシーポリシー</a>
      <a href="/contact/" class="drawer-cat-item">○ お問い合わせ</a>
    </div>

    <!-- ヘッダー -->
    <header class="bg-slate-900 text-white shadow-md py-3 sticky top-0 z-30">
      <div class="max-w-6xl mx-auto px-4 flex items-center justify-between gap-4">
        <!-- ロゴ -->
        <a href="/" class="text-xl font-bold tracking-wider hover:text-blue-300 transition-colors whitespace-nowrap">
          会社員の生活日記
        </a>

        <!-- デスクトップ検索 -->
        <form onsubmit="doSearch(event)" class="hidden md:flex flex-1 max-w-md gap-0 mx-4">
          <input id="headerSearchInput" type="text" placeholder="記事を検索..."
            class="search-input flex-1 bg-white text-slate-900 placeholder-slate-400 border-0 rounded-l-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
          <button type="submit"
            class="bg-blue-500 hover:bg-blue-400 text-white px-4 py-2 rounded-r-lg text-sm font-bold transition-colors border-0 whitespace-nowrap">
            検索
          </button>
        </form>

        <!-- 右側ボタン群 -->
        <div class="flex items-center gap-2">
          <!-- モバイル検索：アイコンのみ -->
          <button onclick="toggleMobileSearch()"
            class="md:hidden bg-white/15 hover:bg-white/25 text-white w-9 h-9 rounded-lg flex items-center justify-center transition-colors border border-white/20">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </button>
          <!-- メニューボタン：スマホはアイコンのみ、PCはアイコン＋テキスト -->
          <button onclick="openDrawer()" class="bg-white text-slate-700 hover:bg-blue-50 rounded-lg transition-colors border border-slate-200 flex items-center justify-center
            w-9 h-9 md:w-auto md:h-auto md:px-3 md:py-1.5 md:gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="3" y1="12" x2="21" y2="12"></line>
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
            <span class="hidden md:inline text-xs font-bold">メニュー</span>
          </button>
        </div>
      </div>

      <!-- モバイル検索バー（トグル） -->
      <div id="mobileSearchBar" class="hidden px-4 pt-2 pb-2 md:hidden bg-slate-800">
        <form onsubmit="doSearch(event)" class="flex gap-0">
          <input id="mobileSearchInput" type="text" placeholder="キーワードを入力"
            class="search-input flex-1 bg-white text-slate-900 placeholder-slate-400 border-0 rounded-l-lg px-3 py-2 text-sm focus:outline-none" />
          <button type="submit"
            class="bg-blue-500 text-white px-4 py-2 rounded-r-lg text-sm font-bold">検索</button>
        </form>
      </div>
    </header>

    <!-- メインコンテンツ -->
    <main class="flex-grow max-w-6xl mx-auto px-4 py-8 w-full">
      <!-- ヒーロー -->
      <div class="mb-6 bg-gradient-to-r from-slate-800 to-slate-900 rounded-xl text-white overflow-hidden">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between px-5 py-4 gap-3">
          <div class="min-w-0">
            <h1 class="text-base md:text-lg font-extrabold leading-tight">会社員の生活日記</h1>
            <p class="text-slate-400 text-xs mt-1 leading-relaxed">40代会社員が、投資・AI/DX・心理学の学びを実体験ベースで記録するブログです。新NISAや高配当株、生成AI活用、メンタルヘルスの学びを、初心者にもわかりやすく整理しています。</p>
          </div>
          <div class="flex gap-2">
            <a href={`/search?q=${encodeURIComponent('投資')}`}
              class="flex flex-col items-center bg-white/10 hover:bg-white/20 rounded-lg px-3 py-2 transition-colors text-center min-w-0 flex-1 sm:flex-none">
              <span class="text-xl leading-none">📊</span>
              <span class="text-xs font-bold mt-1">投資</span>
            </a>
            <a href={`/search?q=${encodeURIComponent('ビジネス・AI・DX')}`}
              class="flex flex-col items-center bg-white/10 hover:bg-white/20 rounded-lg px-3 py-2 transition-colors text-center min-w-0 flex-1 sm:flex-none">
              <span class="text-xl leading-none">🤖</span>
              <span class="text-xs font-bold mt-1 hidden sm:block">ビジネス・AI・DX</span>
              <span class="text-xs font-bold mt-1 sm:hidden">AI・DX</span>
            </a>
            <a href={`/search?q=${encodeURIComponent('心理学')}`}
              class="flex flex-col items-center bg-white/10 hover:bg-white/20 rounded-lg px-3 py-2 transition-colors text-center min-w-0 flex-1 sm:flex-none">
              <span class="text-xl leading-none">🧠</span>
              <span class="text-xs font-bold mt-1">心理学</span>
            </a>
          </div>
        </div>
      </div>

      <!-- YMYL対応：投資免責事項バナー -->
      <div class="mb-6 p-4 bg-yellow-50 border-l-4 border-yellow-500 rounded-lg">
        <div class="flex items-start gap-3">
          <span class="text-yellow-600 font-bold text-lg mt-0.5">⚠️</span>
          <div class="min-w-0">
            <h3 class="font-bold text-yellow-900 text-sm md:text-base mb-1">投資に関する重要な免責事項</h3>
            <p class="text-yellow-800 text-xs md:text-sm leading-relaxed">
              当サイトの投資関連情報は教育・情報提供目的です。特定銘柄の購入推奨ではありません。投資判断は必ずご自身の責任で行い、詳細は<a href="/privacy" class="font-bold hover:underline">プライバシーポリシー</a>をご確認ください。
            </p>
          </div>
        </div>
      </div>

      <!-- 2カラムレイアウト -->
      <div class="flex flex-col lg:flex-row gap-8">

        <!-- メイン：3本柱別 記事一覧 -->
        <div class="flex-1 min-w-0 space-y-8">
          {PILLAR_KEYS.map(pillar => {
            const pillarPosts = postsByPillar[pillar];
            const displayPosts = pillarPosts.slice(0, 4);
            const hasMore = pillarPosts.length > 4;
            return (
              <section>
                <h2 class={`text-lg font-bold border-b-2 ${PILLAR_BORDER[pillar]} pb-2 mb-4 flex items-center justify-between`}>
                  <span class="flex items-center gap-2">
                    <span>{PILLAR_ICONS[pillar]}</span>
                    <span class={PILLAR_TEXT[pillar]}>{pillar}</span>
                  </span>
                  <a href={`/search?q=${encodeURIComponent(pillar)}`}
                    class={`text-xs font-normal ${PILLAR_TEXT[pillar]} hover:underline`}>
                    すべて見る ({pillarPosts.length}件) →
                  </a>
                </h2>

                {displayPosts.length === 0 ? (
                  <p class="text-slate-400 text-sm py-4 text-center border border-dashed border-slate-200 rounded-lg">
                    近日公開予定です。お楽しみに。
                  </p>
                ) : (
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    {displayPosts.map(post => (
                      <a href={`/blog/${post.slug}/`}
                        class="post-card block bg-white rounded-xl shadow-sm border border-slate-200 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 p-4">
                        {post.data.heroImage
                          ? <div class="post-card-wm"><img src={post.data.heroImage} alt={post.data.title} style="width:100%;height:100%;object-fit:cover;" /></div>
                          : <div class="post-card-wm" set:html={getWatermarkSvg(post.data.category || 'マーケット分析', post.data.title)} />
                        }
                        <div class="post-card-content">
                          <div class="flex items-center gap-2 mb-2">
                            <span class={`text-xs font-bold px-2 py-0.5 rounded-full ${PILLAR_BG[pillar]}`}>
                              {post.data.category || 'マーケット分析'}
                            </span>
                            <p class="text-xs text-slate-400">
                              {new Date(post.data.pubDate).toLocaleDateString('ja-JP')}
                            </p>
                          </div>
                          <h3 class="text-sm font-bold text-slate-900 mb-1.5 leading-snug line-clamp-2">
                            {post.data.title}
                          </h3>
                          <p class="text-slate-500 text-xs line-clamp-2 mb-2">{post.data.description}</p>
                          <div class={`flex items-center text-xs font-semibold ${PILLAR_TEXT[pillar]}`}>
                            記事を読む <span class="ml-1">→</span>
                          </div>
                        </div>
                      </a>
                    ))}
                  </div>
                )}

                {hasMore && (
                  <div class="mt-3 text-right">
                    <a href={`/search?q=${encodeURIComponent(pillar)}`}
                      class={`text-xs font-semibold ${PILLAR_TEXT[pillar]} hover:underline`}>
                      {pillar}の記事をもっと見る（残り{pillarPosts.length - 4}件）→
                    </a>
                  </div>
                )}
              </section>
            );
          })}
        </div>

        <!-- サイドバー -->
        <aside class="lg:w-72 flex-shrink-0">

          <!-- 運営者プロフィール -->
          <div class="sidebar-widget">
            <div class="sidebar-widget-title">📝 投稿者</div>
            <div class="sidebar-widget-body text-center py-4">
              <img src="/images/profile.png" alt="ただの会社員"
                class="w-20 h-20 rounded-full mx-auto mb-3 object-cover border-2 border-blue-100 shadow-sm" />
              <p class="font-bold text-slate-900 mb-2">ただの会社員</p>
              <p class="text-xs text-slate-500 leading-relaxed text-left">
                地方在住の中年サラリーマン。投資・AI/DX・心理学の3本柱で発信中。幼少期の愛着障害体験と心理学の学びを経て、妻と子の3人で平和に暮らす。サイドFIREを目指しながら日々学んでいます。
              </p>
              <a href="/about/"
                class="mt-3 inline-block text-xs text-blue-600 hover:text-blue-800 font-semibold">
                プロフィール詳細 →
              </a>
            </div>
          </div>

          <!-- サイト内検索（サイドバー） -->
          <div class="sidebar-widget">
            <div class="sidebar-widget-title">🔍 サイト内検索</div>
            <div class="sidebar-widget-body">
              <form onsubmit="doSearch(event)" class="flex gap-0">
                <input id="sidebarSearchInput" type="text" placeholder="キーワードを入力"
                  class="search-input flex-1 border border-slate-300 rounded-l px-2 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
                <button type="submit"
                  class="bg-blue-600 text-white px-3 py-2 rounded-r hover:bg-blue-700 text-sm font-bold">
                  検索
                </button>
              </form>
            </div>
          </div>

          <!-- 人気記事 -->
          <div class="sidebar-widget">
            <div class="sidebar-widget-title">🏆 人気記事</div>
            <div class="sidebar-widget-body">
              {popularPosts.map((post, i) => (
                <a href={`/blog/${post.slug}/`} class="popular-item">
                  <span class={`popular-rank ${i === 0 ? 'rank-1' : i === 1 ? 'rank-2' : i === 2 ? 'rank-3' : ''}`}>
                    {i + 1}
                  </span>
                  <span class="popular-title">{post.data.title}</span>
                </a>
              ))}
            </div>
          </div>

          <!-- カテゴリーツリー -->
          <div class="sidebar-widget">
            <div class="sidebar-widget-title">📂 カテゴリー</div>
            <div class="py-2">
              {PILLAR_KEYS.map(pillar => {
                const cats = PILLAR_CATEGORIES[pillar];
                const total = cats.reduce((s, c) => s + (categoryCount[c] || 0), 0);
                return (
                  <>
                    <a href={`/search?q=${encodeURIComponent(pillar)}`}
                      class={`flex items-center justify-between px-3 py-2 hover:bg-slate-50 font-bold text-sm ${PILLAR_TEXT[pillar]}`}>
                      <span>{PILLAR_ICONS[pillar]} {pillar}</span>
                      {total > 0 && <span class="cat-badge">{total}</span>}
                    </a>
                    <div class="ml-4 mb-1 border-l-2 border-slate-200 pl-2">
                      {cats.filter(cat => (categoryCount[cat] || 0) > 0).map(cat => (
                        <a href={`/search?q=${encodeURIComponent(cat)}`}
                          class="flex items-center justify-between py-1 px-2 hover:bg-slate-50 rounded text-xs text-slate-600 hover:text-blue-600">
                          <span>{cat}</span>
                          <span class="text-slate-400">{categoryCount[cat]}</span>
                        </a>
                      ))}
                    </div>
                  </>
                );
              })}
            </div>
          </div>

        </aside>
      </div>
    </main>

    <footer class="bg-slate-900 text-slate-400 text-center py-6 mt-auto">
      <div class="text-xs pb-4 mb-4 border-b border-slate-700 flex items-center justify-center gap-2 flex-wrap">
        <span>⚠️</span>
        <span>当サイトの投資情報は教育目的です。特定銘柄の購入推奨ではありません。</span>
        <a href="/privacy/" class="text-blue-400 hover:text-blue-300">詳細</a>
      </div>
      <p class="text-sm">&copy; 2026 会社員の生活日記. All rights reserved.</p>
      <nav class="flex justify-center gap-6 mt-3 text-xs flex-wrap">
        <a href="/about/" class="hover:text-blue-300 transition-colors">運営者について</a>
        <a href="/contact/" class="hover:text-blue-300 transition-colors">お問い合わせ</a>
        <a href="/privacy/" class="hover:text-blue-300 transition-colors">プライバシーポリシー</a>
      </nav>
    </footer>

    <script is:inline>
      // ── ドロワー開閉 ───────────────────────────────────────────
      function openDrawer() {
        document.getElementById('drawer').classList.add('open');
        document.getElementById('drawerOverlay').classList.add('open');
        document.body.style.overflow = 'hidden';
      }
      function closeDrawer() {
        document.getElementById('drawer').classList.remove('open');
        document.getElementById('drawerOverlay').classList.remove('open');
        document.body.style.overflow = '';
      }

      // モバイル検索トグル
      function toggleMobileSearch() {
        const bar = document.getElementById('mobileSearchBar');
        bar.classList.toggle('hidden');
        if (!bar.classList.contains('hidden')) {
          document.getElementById('mobileSearchInput').focus();
        }
      }

      // 検索 → /search?q= ページに遷移
      function doSearch(e) {
        e.preventDefault();
        const inputs = ['headerSearchInput', 'sidebarSearchInput', 'drawerSearchInput', 'mobileSearchInput'];
        let q = '';
        for (const id of inputs) {
          const el = document.getElementById(id);
          if (el && el.value.trim()) { q = el.value.trim(); break; }
        }
        if (!q) return;
        window.location.href = '/search?q=' + encodeURIComponent(q);
      }
    </script>
  </body>
</html>
