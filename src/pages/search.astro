---
import { getCollection } from 'astro:content';

const googleAnalyticsId = import.meta.env.PUBLIC_GOOGLE_ANALYTICS_ID || 'G-2F8G5290KT';
const posts = await getCollection('blog');
posts.sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());
// 全記事データをJSONとしてクライアントに渡す
const postsJson = JSON.stringify(posts.map(p => ({
  slug: p.slug,
  title: p.data.title,
  description: p.data.description || '',
  category: p.data.category || 'マーケット分析',
  pillar: p.data.pillar || '投資',
  pubDate: new Date(p.data.pubDate).toLocaleDateString('ja-JP'),
})));
---
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>検索結果 | 会社員の生活日記</title>
    <script>document.addEventListener('DOMContentLoaded',()=>{const q=new URLSearchParams(location.search).get('q');if(q)document.title=`「${q}」の検索結果 | 会社員の生活日記`});</script>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Google Analytics -->
    {googleAnalyticsId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`}></script>
        <script define:vars={{ googleAnalyticsId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', googleAnalyticsId);
        </script>
      </>
    )}
  </head>
  <body class="bg-slate-50 text-slate-800 font-sans min-h-screen flex flex-col">
    <header class="bg-slate-900 text-white shadow-md py-3 sticky top-0 z-30">
      <div class="max-w-4xl mx-auto px-4 flex items-center gap-4">
        <a href="/" class="text-xl font-bold hover:text-blue-300 transition-colors whitespace-nowrap">
          会社員の生活日記
        </a>
        <form id="searchForm" class="flex flex-1 gap-2">
          <input id="searchInput" type="text" placeholder="キーワードを入力..."
            class="flex-1 bg-white text-slate-900 border border-slate-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          <button type="submit"
            class="bg-blue-600 hover:bg-blue-500 text-white px-5 py-2 rounded-lg text-sm font-bold transition-colors">
            検索
          </button>
        </form>
        <a href="/" class="text-sm text-slate-300 hover:text-blue-300 whitespace-nowrap hidden md:block">← トップ</a>
      </div>
    </header>

    <main class="flex-grow max-w-4xl mx-auto px-4 py-8 w-full">
      <div id="resultHeader" class="mb-6">
        <p id="resultMsg" class="text-slate-500 text-sm"></p>
      </div>
      <div id="resultGrid" class="grid grid-cols-1 md:grid-cols-2 gap-5"></div>
      <div id="noResult" class="hidden text-center py-16">
        <p class="text-4xl mb-4">🔍</p>
        <p class="text-slate-500">「<span id="noResultQuery"></span>」に一致する記事が見つかりませんでした。</p>
        <a href="/" class="mt-4 inline-block text-blue-600 hover:underline text-sm">← トップに戻る</a>
      </div>
    </main>

    <footer class="bg-slate-900 text-slate-400 text-center py-6 mt-auto">
      <p class="text-sm">&copy; 2026 会社員の生活日記. All rights reserved.</p>
    </footer>

    <script define:vars={{ postsJson }}>
      const ALL_POSTS = JSON.parse(postsJson);

      // ── 検索結果カードに透かし背景を適用 ──
    const SVG_URLS = {
      chart: "data:image/svg+xml,%3Csvg viewBox='0 0 320 170' xmlns='http://www.w3.org/2000/svg' preserveAspectRatio='xMidYMid slice'%3E%3Cline x1='0' y1='140' x2='320' y2='140' stroke='%231d4ed8' stroke-width='0.8'/%3E%3Cline x1='0' y1='70' x2='320' y2='70' stroke='%231d4ed8' stroke-width='0.5' stroke-dasharray='4,4'/%3E%3Cpath d='M0,130 L80,108 L160,80 L240,40 L320,15 L320,150 L0,150Z' fill='%231d4ed8' opacity='0.3'/%3E%3Cpolyline points='0,130 80,108 160,80 240,40 320,15' fill='none' stroke='%231d4ed8' stroke-width='2.5' stroke-linecap='round'/%3E%3C/svg%3E",
      ship:  "data:image/svg+xml,%3Csvg viewBox='0 0 320 170' xmlns='http://www.w3.org/2000/svg' preserveAspectRatio='xMidYMid slice'%3E%3Cpath d='M0,125 Q80,110 160,125 Q240,140 320,125 L320,170 L0,170Z' fill='%23166534' opacity='0.2'/%3E%3Cpath d='M25,122 L25,80 L270,80 L295,122 Z' fill='none' stroke='%23166534' stroke-width='2'/%3E%3Crect x='55' y='52' width='170' height='28' fill='none' stroke='%23166534' stroke-width='1.5' rx='2'/%3E%3Crect x='65' y='58' width='22' height='14' fill='none' stroke='%23166534' stroke-width='1' rx='1'/%3E%3Crect x='91' y='58' width='22' height='14' fill='none' stroke='%23166534' stroke-width='1' rx='1'/%3E%3Crect x='117' y='58' width='22' height='14' fill='none' stroke='%23166534' stroke-width='1' rx='1'/%3E%3Crect x='143' y='58' width='22' height='14' fill='none' stroke='%23166534' stroke-width='1' rx='1'/%3E%3C/svg%3E",
      bank:  "data:image/svg+xml,%3Csvg viewBox='0 0 320 170' xmlns='http://www.w3.org/2000/svg' preserveAspectRatio='xMidYMid slice'%3E%3Crect x='55' y='72' width='210' height='90' fill='none' stroke='%231d4ed8' stroke-width='2'/%3E%3Cpath d='M45,72 L160,18 L275,72 Z' fill='none' stroke='%231d4ed8' stroke-width='2'/%3E%3Crect x='75' y='72' width='13' height='90' fill='none' stroke='%231d4ed8' stroke-width='1.5'/%3E%3Crect x='110' y='72' width='13' height='90' fill='none' stroke='%231d4ed8' stroke-width='1.5'/%3E%3Crect x='145' y='72' width='13' height='90' fill='none' stroke='%231d4ed8' stroke-width='1.5'/%3E%3Crect x='180' y='72' width='13' height='90' fill='none' stroke='%231d4ed8' stroke-width='1.5'/%3E%3Crect x='215' y='72' width='13' height='90' fill='none' stroke='%231d4ed8' stroke-width='1.5'/%3E%3Crect x='140' y='122' width='40' height='40' fill='none' stroke='%231d4ed8' stroke-width='1.5'/%3E%3C/svg%3E",
      nisa:  "data:image/svg+xml,%3Csvg viewBox='0 0 320 170' xmlns='http://www.w3.org/2000/svg' preserveAspectRatio='xMidYMid slice'%3E%3Cline x1='18' y1='8' x2='18' y2='158' stroke='%236b21a8' stroke-width='1.5'/%3E%3Cline x1='18' y1='158' x2='225' y2='158' stroke='%236b21a8' stroke-width='1.5'/%3E%3Crect x='28' y='132' width='24' height='26' fill='%236b21a8' opacity='0.3' rx='2'/%3E%3Crect x='58' y='115' width='24' height='43' fill='%236b21a8' opacity='0.35' rx='2'/%3E%3Crect x='88' y='96' width='24' height='62' fill='%236b21a8' opacity='0.4' rx='2'/%3E%3Crect x='118' y='74' width='24' height='84' fill='%236b21a8' opacity='0.45' rx='2'/%3E%3Crect x='148' y='50' width='24' height='108' fill='%236b21a8' opacity='0.5' rx='2'/%3E%3Crect x='178' y='24' width='24' height='134' fill='%236b21a8' opacity='0.6' rx='2'/%3E%3C/svg%3E",
      compound: "data:image/svg+xml,%3Csvg viewBox='0 0 320 170' xmlns='http://www.w3.org/2000/svg' preserveAspectRatio='xMidYMid slice'%3E%3Cpath d='M0,165 Q80,155 160,120 Q240,80 320,10 L320,170 L0,170Z' fill='%23166534' opacity='0.25'/%3E%3Cpath d='M0,165 Q80,155 160,120 Q240,80 320,10' fill='none' stroke='%23166534' stroke-width='2.5'/%3E%3Ccircle cx='80' cy='148' r='12' fill='none' stroke='%23166534' stroke-width='1.5'/%3E%3Ccircle cx='160' cy='118' r='22' fill='none' stroke='%23166534' stroke-width='1.8'/%3E%3Ccircle cx='260' cy='62' r='38' fill='none' stroke='%23166534' stroke-width='2'/%3E%3C/svg%3E",
      portfolio: "data:image/svg+xml,%3Csvg viewBox='0 0 320 170' xmlns='http://www.w3.org/2000/svg' preserveAspectRatio='xMidYMid slice'%3E%3Ccircle cx='95' cy='88' r='70' fill='none' stroke='%2392400e' stroke-width='1'/%3E%3Cpath d='M95,88 L95,18 A70,70 0 0,1 156,123 Z' fill='%2392400e' opacity='0.5'/%3E%3Cpath d='M95,88 L156,123 A70,70 0 0,1 34,123 Z' fill='%2392400e' opacity='0.3'/%3E%3Cpath d='M95,88 L34,53 A70,70 0 0,1 95,18 Z' fill='%2392400e' opacity='0.08'/%3E%3Ccircle cx='95' cy='88' r='30' fill='white'/%3E%3Crect x='190' y='20' width='115' height='140' fill='none' stroke='%2392400e' stroke-width='1' rx='4'/%3E%3Cline x1='190' y1='38' x2='305' y2='38' stroke='%2392400e' stroke-width='1'/%3E%3Crect x='197' y='45' width='27' height='18' rx='2' fill='%2392400e' opacity='0.4'/%3E%3Crect x='228' y='45' width='27' height='18' rx='2' fill='%2392400e' opacity='0.2'/%3E%3Crect x='259' y='45' width='27' height='18' rx='2' fill='%2392400e' opacity='0.4'/%3E%3C/svg%3E",
      search: "data:image/svg+xml,%3Csvg viewBox='0 0 320 170' xmlns='http://www.w3.org/2000/svg' preserveAspectRatio='xMidYMid slice'%3E%3Ccircle cx='130' cy='80' r='60' fill='none' stroke='%23166534' stroke-width='2'/%3E%3Ccircle cx='130' cy='80' r='42' fill='none' stroke='%23166534' stroke-width='1' opacity='0.5'/%3E%3Cline x1='178' y1='128' x2='255' y2='160' stroke='%23166534' stroke-width='5' stroke-linecap='round'/%3E%3Cline x1='100' y1='68' x2='160' y2='68' stroke='%23166534' stroke-width='2' stroke-linecap='round'/%3E%3Cline x1='100' y1='80' x2='160' y2='80' stroke='%23166534' stroke-width='2' stroke-linecap='round'/%3E%3Cline x1='100' y1='92' x2='145' y2='92' stroke='%23166534' stroke-width='2' stroke-linecap='round'/%3E%3C/svg%3E",
    };
    function getWmUrl(cat, title) {
      const t = (title || '').toLowerCase();
      if (t.includes('海運') || t.includes('郵船') || t.includes('船')) return SVG_URLS.ship;
      if (t.includes('銀行') || t.includes('金利') || t.includes('日銀')) return SVG_URLS.bank;
      if (t.includes('nisa') || t.includes('非課税')) return SVG_URLS.nisa;
      if (t.includes('複利') || t.includes('再投資')) return SVG_URLS.compound;
      if (t.includes('ポートフォリオ') || t.includes('毎月')) return SVG_URLS.portfolio;
      if (cat === 'キーワード解説') return SVG_URLS.search;
      if (cat === 'コラム') return SVG_URLS.compound;
      return SVG_URLS.chart;
    }
    // 検索結果レンダリング後にカードへ透かしを適用

    function renderResults(q) {
        const query = q.trim().toLowerCase();
        const grid = document.getElementById('resultGrid');
        const noResult = document.getElementById('noResult');
        const msg = document.getElementById('resultMsg');

        // フィルタリング
        const filtered = query
          ? ALL_POSTS.filter(p =>
              p.pillar.toLowerCase() === query ||            // 柱完全一致（最優先）
              p.category.toLowerCase() === query ||          // カテゴリー完全一致
              p.category.toLowerCase().includes(query) ||   // カテゴリー部分一致
              p.title.toLowerCase().includes(query) ||
              p.description.toLowerCase().includes(query)
            )
          : ALL_POSTS;

        // メッセージ
        if (query) {
          // カテゴリー完全一致の場合は「#カテゴリー名」表示
          const isCat = ALL_POSTS.some(p => p.category.toLowerCase() === query);
          if (isCat) {
            msg.textContent = `# ${q} の記事：${filtered.length}件`;
          } else {
            msg.textContent = `「${q}」の検索結果：${filtered.length}件`;
          }
        } else {
          msg.textContent = `全記事：${filtered.length}件`;
        }

        // 結果表示
        grid.innerHTML = '';
        if (filtered.length === 0) {
          noResult.classList.remove('hidden');
          document.getElementById('noResultQuery').textContent = q;
          return;
        }
        noResult.classList.add('hidden');

        filtered.forEach(p => {
          const wmUrl = getWmUrl(p.category, p.title);
          
          grid.innerHTML += `
            <a href="/blog/${p.slug}"
              class="block bg-white rounded-xl shadow-sm border border-slate-200 hover:shadow-md hover:border-blue-400 hover:-translate-y-0.5 transition-all duration-200 p-5"
              style="position:relative; overflow:hidden;">
              
              <!-- 背景画像を独立したdivとして配置 -->
              <!-- URLのクォーテーションの使い方を調整しています -->
              <div style="position:absolute; inset:0; width:100%; height:100%; background-image:url(&quot;${wmUrl}&quot;); background-size:cover; background-position:center; background-repeat:no-repeat; opacity:0.1; pointer-events:none;"></div>
              
              <div style="position:relative; z-index:10;">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-xs bg-blue-100 text-blue-700 font-bold px-2 py-0.5 rounded-full">${p.category}</span>
                  <p class="text-xs text-slate-400">${p.pubDate}</p>
                </div>
                <h3 class="text-base font-bold text-slate-900 mb-2 leading-snug">${p.title}</h3>
                <p class="text-slate-500 text-xs line-clamp-2 mb-3">${p.description}</p>
                <div class="flex items-center text-blue-600 text-xs font-semibold">記事を読む →</div>
              </div>
            </a>`;
        });
      }

      // URLパラメータから検索クエリ取得
      const params = new URLSearchParams(window.location.search);
      const initialQ = params.get('q') || '';
      const input = document.getElementById('searchInput');
      input.value = initialQ;
      renderResults(initialQ);

      // フォーム送信
      document.getElementById('searchForm').addEventListener('submit', e => {
        e.preventDefault();
        const q = input.value;
        // URLを更新
        const url = new URL(window.location.href);
        url.searchParams.set('q', q);
        window.history.pushState({}, '', url);
        renderResults(q);
      });

      // 入力のたびにリアルタイム検索
      input.addEventListener('input', () => renderResults(input.value));

    </script>
  </body>
</html>
