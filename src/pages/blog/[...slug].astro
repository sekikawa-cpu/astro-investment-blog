---
import { getCollection } from 'astro:content';

// すべての記事のURLを自動生成する設定
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>{post.data.title}</title>
    <style>
      body { font-family: sans-serif; max-width: 800px; margin: 0 auto; padding: 20px; line-height: 1.6; color: #333; }
      table { border-collapse: collapse; width: 100%; margin: 20px 0; font-size: 0.95rem; }
      th, td { border: 1px solid #ddd; padding: 12px; text-align: left; }
      th { background-color: #f8f9fa; font-weight: bold; }
      a.back-link { display: inline-block; margin-bottom: 20px; color: #1a73e8; text-decoration: none; }
      a.back-link:hover { text-decoration: underline; }
    </style>
  </head>
  <body>
    <a href="/" class="back-link">← トップページに戻る</a>
    
    <h1>{post.data.title}</h1>
    <p style="color: #666;">
      <strong>公開日:</strong> {new Date(post.data.pubDate).toLocaleDateString('ja-JP')} | 
      <strong>カテゴリ:</strong> {post.data.category}
    </p>
    <hr />
    
    <div class="article-content">
      <Content />
    </div>
  </body>
</html>
