---
import { getCollection } from 'astro:content';

const googleAnalyticsId = import.meta.env.PUBLIC_GOOGLE_ANALYTICS_ID || 'G-7WDEFXG48Y';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  const publishedEntries = blogEntries.filter(e => !e.data.draft);
  return publishedEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry, allEntries: publishedEntries },
  }));
}

const { entry, allEntries } = Astro.props;
const { Content } = await entry.render();
const { title, pubDate, description, tags = [], author, category, pillar, noindex = false, heroImage } = entry.data;

const pillarEmoji = pillar === '投資' ? '📊' : pillar === 'ビジネス・AI・DX' ? '💼' : pillar === '心理学' ? '🧠' : '';

const relatedPosts = allEntries
  .filter(e => e.data.category === category && e.slug !== entry.slug && !e.data.draft)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);

const fullUrl = `https://tech-wealth-mind.com/blog/${entry.slug}/`;
const ogImageUrl = heroImage
  ? `https://tech-wealth-mind.com${heroImage}`
  : 'https://tech-wealth-mind.com/images/profile.png';

const schemaData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "image": ogImageUrl,
  "datePublished": new Date(pubDate).toISOString(),
  "author": {
    "@type": "Person",
    "name": author || "ただの会社員",
    "url": "https://tech-wealth-mind.com/profile"
  },
  "publisher": {
    "@type": "Organization",
    "name": "会社員の生活日記",
    "url": "https://tech-wealth-mind.com"
  },
  "url": fullUrl,
  "articleSection": category,
  "keywords": tags.join(", ")
};

const breadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://tech-wealth-mind.com/" },
    { "@type": "ListItem", "position": 2, "name": pillar || "記事", "item": `https://tech-wealth-mind.com/search?q=${encodeURIComponent(pillar || '')}` },
    { "@type": "ListItem", "position": 3, "name": category || "記事", "item": `https://tech-wealth-mind.com/search?q=${encodeURIComponent(category || '')}` },
    { "@type": "ListItem", "position": 4, "name": title, "item": fullUrl }
  ]
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>{title} | 会社員の生活日記</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="referrer" content="no-referrer" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={fullUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- OGP / Twitter Card -->
    <meta property="og:type" content="article" />
    <meta property="og:url" content={fullUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="会社員の生活日記" />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <!-- 構造化データ -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />
    <!-- Google Analytics -->
    {googleAnalyticsId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`}></script>
        <script define:vars={{ googleAnalyticsId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', googleAnalyticsId);
        </script>
      </>
    )}
    <!-- Google AdSense -->
    <meta name="google-adsense-account" content="ca-pub-7499855875738477">
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7499855875738477"
     crossorigin="anonymous"></script>
  </head>

  <body class="bg-slate-50 text-slate-800 font-sans min-h-screen flex flex-col">
    <header class="bg-slate-900 text-white shadow-md py-4">
      <div class="max-w-5xl mx-auto px-4 flex justify-between items-center">
        <a href="/" class="text-2xl font-bold hover:text-blue-300 transition-colors">
          会社員の生活日記
</a>
        <a href="/" class="text-sm text-slate-300 hover:text-blue-300 transition-colors">
          ← 記事一覧
        </a>
      </div>
    </header>

    <main class="flex-grow max-w-5xl mx-auto px-4 py-10 w-full">
      <nav aria-label="パンくずリスト" class="mb-4">
        <ol class="flex flex-wrap items-center gap-1 text-xs text-slate-500">
          <li><a href="/" class="hover:text-blue-600 transition-colors">ホーム</a></li>
          {pillar && (
            <>
              <li class="text-slate-300" aria-hidden="true">›</li>
              <li>
                <a href={`/search?q=${encodeURIComponent(pillar)}`} class="hover:text-blue-600 transition-colors">
                  {pillarEmoji} {pillar}
                </a>
              </li>
            </>
          )}
          {category && (
            <>
              <li class="text-slate-300" aria-hidden="true">›</li>
              <li>
                <a href={`/search?q=${encodeURIComponent(category)}`} class="hover:text-blue-600 transition-colors">
                  {category}
                </a>
              </li>
            </>
          )}
          <li class="text-slate-300" aria-hidden="true">›</li>
          <li class="text-slate-700 font-medium line-clamp-1 max-w-[200px] md:max-w-xs" aria-current="page">{title}</li>
        </ol>
      </nav>

      <article class="bg-white shadow-sm rounded-lg overflow-hidden">
        <header class="px-6 md:px-12 pt-10 pb-8 border-b border-slate-100">
          <div class="flex flex-wrap items-center gap-3 mb-4">
            {category && (
              <span class="bg-blue-100 text-blue-700 text-xs font-bold px-3 py-1 rounded-full">
                {category}
              </span>
            )}
            <p class="text-sm text-blue-600 font-bold">
              {new Date(pubDate).toLocaleDateString('ja-JP', {
                year: 'numeric', month: 'long', day: 'numeric'
              })}
            </p>
          </div>
          <h1 class="text-2xl md:text-3xl font-extrabold text-slate-900 leading-tight">
            {title}
          </h1>
          {author && (
            <p class="text-sm text-slate-500 mt-4">執筆: {author}</p>
          )}
        </header>

        {category === '生きづらさと回復' ? (
          <div class="content-warning mx-6 md:mx-12 mt-6">
            <div class="content-warning-header">
              <span>📢</span>
              <strong>コンテンツ警告</strong>
            </div>
            <p class="content-warning-body">※本記事には家庭内の困難な経験に関する記述が含まれます。回復プロセスを共有する目的で執筆しています。</p>
          </div>
        ) : null}

        {heroImage && (
          <div class="w-full">
            <img src={heroImage} alt={title} class="w-full h-auto object-cover" />
          </div>
        )}

        <div class="markdown-content px-6 md:px-12 py-10">
          <Content />
        </div>

        {tags.length > 0 && (
          <div class="px-6 md:px-12 pb-8 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="bg-slate-100 text-slate-700 text-xs px-3 py-1 rounded-full">
                #{tag}
              </span>
            ))}
          </div>
        )}

        {relatedPosts.length > 0 && (
          <div class="px-6 md:px-12 py-8 border-t border-slate-100">
            <h2 class="text-sm font-bold text-slate-600 mb-4 flex items-center gap-1">
              <span>📌</span> あわせて読みたい
            </h2>
            <ul class="flex flex-col gap-2">
              {relatedPosts.map(post => (
                <li>
                  <a
                    href={`/blog/${post.slug}/`}
                    class="flex items-center gap-3 p-3 rounded-lg border border-slate-100 hover:border-blue-200 hover:bg-slate-50 transition-colors group"
                  >
                    {post.data.heroImage ? (
                      <img
                        src={post.data.heroImage}
                        alt={post.data.title}
                        class="w-14 h-10 object-cover rounded flex-shrink-0"
                      />
                    ) : (
                      <div class="w-14 h-10 bg-slate-100 rounded flex-shrink-0 flex items-center justify-center text-slate-400 text-xs">
                        📄
                      </div>
                    )}
                    <div class="min-w-0">
                      <span class="text-xs text-slate-400 block mb-0.5">
                        {new Date(post.data.pubDate).toLocaleDateString('ja-JP', { year: 'numeric', month: 'short', day: 'numeric' })}
                      </span>
                      <span class="text-sm font-semibold text-slate-800 group-hover:text-blue-600 transition-colors leading-snug line-clamp-2">
                        {post.data.title}
                      </span>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        {pillar === '投資' && (
          <div class="article-disclaimer article-disclaimer--invest px-6 md:px-12 pb-6">
            <div class="article-disclaimer__header">
              <span>⚠️</span>
              <strong>投資に関する免責事項</strong>
            </div>
            <p>本記事は筆者個人の投資記録であり、特定銘柄の売買を推奨するものではありません。掲載情報は執筆時点のものであり、最新情報は各自でご確認ください。投資判断はご自身の責任で行ってください。</p>
          </div>
        )}

        {pillar === '心理学' && (
          <div class="article-disclaimer article-disclaimer--health px-6 md:px-12 pb-6">
            <div class="article-disclaimer__header">
              <span>🩺</span>
              <strong>医療・専門家への相談について</strong>
            </div>
            <p>本記事は筆者個人の学習記録および体験をもとにした情報提供を目的としています。医療行為や治療の代替となるものではありません。心理的な課題や体調不良については、医師・臨床心理士・カウンセラーなど専門家へのご相談をお勧めします。</p>
          </div>
        )}

        <div class="px-6 md:px-12 pb-10 pt-6 border-t border-slate-100">
          <a href="/" class="text-blue-600 hover:text-blue-800 font-semibold text-sm">
            ← 記事一覧に戻る
          </a>
        </div>
      </article>
    </main>

    <footer class="bg-slate-900 text-slate-400 text-center py-8 mt-auto">
      <div class="text-xs pb-4 mb-4 border-b border-slate-700 flex items-center justify-center gap-2 flex-wrap px-4">
        <span>⚠️</span>
        <span>当サイトの投資情報は教育目的です。特定銘柄の購入推奨ではありません。</span>
        <a href="/privacy/" class="text-blue-400 hover:text-blue-300">詳細</a>
      </div>
      <p class="text-sm">&copy; 2026 会社員の生活日記. All rights reserved.</p>
      <nav class="flex justify-center gap-6 mt-3 text-xs flex-wrap">
        <a href="/about/" class="hover:text-blue-300 transition-colors">運営者について</a>
        <a href="/contact/" class="hover:text-blue-300 transition-colors">お問い合わせ</a>
        <a href="/privacy/" class="hover:text-blue-300 transition-colors">プライバシーポリシー</a>
      </nav>
    </footer>
  </body>
</html>

<style is:global>
  /* ===== 記事末尾免責ブロック ===== */
  .article-disclaimer {
    margin: 0 0 1rem;
    padding: 1rem 1.25rem;
    border-radius: 0 0.5rem 0.5rem 0;
    font-size: 0.84rem;
    line-height: 1.75;
  }
  .article-disclaimer__header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    font-size: 0.88rem;
  }
  .article-disclaimer p { margin: 0; }
  .article-disclaimer--invest {
    background: #fffbeb;
    border-left: 4px solid #f59e0b;
    color: #78350f;
  }
  .article-disclaimer--invest .article-disclaimer__header { color: #b45309; }
  .article-disclaimer--health {
    background: #f0f9ff;
    border-left: 4px solid #38bdf8;
    color: #0c4a6e;
  }
  .article-disclaimer--health .article-disclaimer__header { color: #0369a1; }

  /* ===== コンテンツ警告 ===== */
  .content-warning {
    padding: 1rem 1.25rem;
    background: #f0fdf4;
    border: 1px solid #86efac;
    border-left: 4px solid #22c55e;
    border-radius: 0 0.5rem 0.5rem 0;
    margin-bottom: 0;
  }
  .content-warning-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    color: #15803d;
    margin-bottom: 0.5rem;
    font-size: 0.92rem;
  }
  .content-warning-body {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.7;
    color: #166534;
  }

  /* ===== 導入文 ===== */
  .markdown-content .lead-text {
    position: relative;
    font-size: 1.05rem;
    line-height: 1.9;
    color: #334155;
    margin-bottom: 2.5rem;
    padding: 1.5rem 1.75rem;
    background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
    border-radius: 0.75rem;
    border-left: 4px solid #3b82f6;
    overflow: hidden;
  }

  /* ===== 見出し ===== */
  .markdown-content h2 {
    font-size: 1.5rem;
    font-weight: 800;
    color: #0f172a;
    margin: 3rem 0 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 3px solid #3b82f6;
  }
  .markdown-content h2:first-child { margin-top: 0; }
  .markdown-content h3 {
    font-size: 1.15rem;
    font-weight: 700;
    color: #1e293b;
    margin: 2rem 0 0.75rem;
    padding-left: 0.75rem;
    border-left: 4px solid #60a5fa;
  }
  .markdown-content p {
    font-size: 1rem;
    line-height: 1.85;
    color: #334155;
    margin: 0.75rem 0 1.25rem;
  }

  /* ===== ニューストピック ===== */
  .markdown-content .news-list {
    display: flex;
    flex-direction: column;
    margin: 1.5rem 0 2rem;
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    overflow: hidden;
    background: #fff;
  }
  .markdown-content .news-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.75rem 1rem;
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid #f1f5f9;
    color: #1e293b;
    text-decoration: none;
    transition: background-color 0.15s;
    align-items: center;
  }
  .markdown-content .news-item:last-child { border-bottom: none; }
  .markdown-content .news-item:hover { background: #f8fafc; }
  .markdown-content .news-item .news-date {
    font-size: 0.78rem;
    color: #64748b;
    white-space: nowrap;
    font-family: ui-monospace, Menlo, monospace;
  }
  .markdown-content .news-item .news-title {
    font-size: 0.95rem;
    font-weight: 500;
    color: #1e293b;
    line-height: 1.5;
  }
  .markdown-content .news-item:hover .news-title {
    color: #2563eb;
    text-decoration: underline;
  }
  .markdown-content .news-item .news-source {
    font-size: 0.75rem;
    color: #94a3b8;
    background: #f1f5f9;
    padding: 0.15rem 0.6rem;
    border-radius: 9999px;
    white-space: nowrap;
  }
  @media (max-width: 640px) {
    .markdown-content .news-item {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }
  }

  /* ===== ランキングテーブル ===== */
  .markdown-content .table-wrapper {
    overflow-x: auto;
    margin: 2rem 0;
    border-radius: 0.5rem;
    border: 1px solid #e2e8f0;
    box-shadow: 0 1px 3px rgba(0,0,0,.05);
  }
  .markdown-content table.stock-table {
    width: 100% !important;
    border-collapse: collapse !important;
    background: #fff !important;
    font-size: 0.875rem !important;
    margin: 0 !important;
  }
  .markdown-content table.stock-table thead th {
    background: #1e293b !important;
    color: #fff !important;
    padding: 0.85rem 0.75rem !important;
    font-weight: 700 !important;
    text-align: center !important;
    border-bottom: 2px solid #0f172a !important;
    white-space: nowrap;
  }
  .markdown-content table.stock-table tbody td {
    padding: 0.75rem !important;
    border-bottom: 1px solid #f1f5f9 !important;
    vertical-align: middle !important;
  }
  .markdown-content table.stock-table tbody tr:hover { background: #f8fafc !important; }
  /* 前日比プラス → 赤 */
  .markdown-content table.stock-table tbody tr.red-row td {
    color: #ef4444 !important;
    font-weight: 500 !important;
  }
  /* 前日比マイナス → ダークグリーン */
  .markdown-content table.stock-table tbody tr.green-row td {
    color: #064e3b !important;
    font-weight: 700 !important;
  }
  .markdown-content table.stock-table tbody tr.red-row td strong,
  .markdown-content table.stock-table tbody tr.green-row td strong {
    color: inherit !important;
    font-weight: 800 !important;
  }
  .markdown-content table.stock-table tbody td strong {
    font-weight: 700 !important;
    color: #0f172a;
  }
  .markdown-content table.stock-table .text-center { text-align: center !important; }
  .markdown-content table.stock-table .text-right  { text-align: right  !important; }

  /* ===== 書籍紹介 ===== */
  .markdown-content .book-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    margin: 1.5rem 0;
    padding: 1.5rem;
    border: 1px solid #e2e8f0;
    border-radius: 0.75rem;
    background: #f8fafc;
    transition: all 0.2s ease;
  }
  @media (min-width: 640px) {
    .markdown-content .book-item { flex-direction: row; align-items: flex-start; }
  }
  .markdown-content .book-item:hover {
    box-shadow: 0 4px 12px rgba(0,0,0,.08);
    transform: translateY(-2px);
  }
  /* 書影リンク：画像全体をクリッカブルに */
  .markdown-content .book-cover-link {
    display: block;
    flex-shrink: 0;
    text-decoration: none;
    border-radius: 0.375rem;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .markdown-content .book-cover-link:hover {
    opacity: 0.85;
    transform: scale(1.03);
  }
  .markdown-content .book-item img {
    width: 110px;
    height: 155px;
    object-fit: contain;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 0.375rem;
    box-shadow: 0 2px 8px rgba(0,0,0,.12);
    margin: 0;
    display: block;
    cursor: pointer;
  }
  .markdown-content .book-info { flex: 1; min-width: 0; }
  .markdown-content .book-item strong {
    font-size: 1rem;
    display: block;
    margin-bottom: 0.3rem;
    color: #0f172a;
    font-weight: 700;
    line-height: 1.5;
  }
  .markdown-content .book-item strong a {
    color: #0f172a;
    text-decoration: none;
    transition: color 0.15s;
  }
  .markdown-content .book-item strong a:hover { color: #2563eb; text-decoration: underline; }
  .markdown-content .book-item .book-author {
    font-size: 0.8rem !important;
    color: #64748b !important;
    margin: 0 0 0.4rem !important;
    line-height: 1.4 !important;
  }
  .markdown-content .book-item p {
    font-size: 0.9rem;
    color: #475569;
    margin: 0;
    line-height: 1.7;
  }

  /* ===== 免責 ===== */
  .markdown-content .disclaimer-note {
    margin-top: 2rem;
    padding: 1rem 1.25rem;
    background: #fef3c7;
    border-left: 4px solid #f59e0b;
    border-radius: 0 0.375rem 0.375rem 0;
    font-size: 0.85rem;
    line-height: 1.7;
    color: #78350f;
  }
  .markdown-content hr {
    border: none;
    border-top: 1px solid #e2e8f0;
    margin: 2.5rem 0;
  }

  /* ===== コラム内 Markdown テーブル（stock-tableクラスなし） ===== */
  .markdown-content table:not(.stock-table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0 2rem;
    font-size: 0.9rem;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    overflow: hidden;
    display: table;
  }
  .markdown-content table:not(.stock-table) thead th {
    background: #1e293b;
    color: #fff;
    padding: 0.75rem 1rem;
    font-weight: 700;
    text-align: left;
    border-bottom: 2px solid #0f172a;
    white-space: nowrap;
  }
  .markdown-content table:not(.stock-table) tbody td {
    padding: 0.7rem 1rem;
    border-bottom: 1px solid #f1f5f9;
    color: #334155;
    vertical-align: middle;
    line-height: 1.6;
  }
  .markdown-content table:not(.stock-table) tbody tr:last-child td {
    border-bottom: none;
  }
  .markdown-content table:not(.stock-table) tbody tr:hover {
    background: #f8fafc;
  }
  /* テーブルが画面幅を超えた場合にスクロール */
  .markdown-content .table-scroll-wrapper {
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .markdown-content table:not(.stock-table) thead th:not(:last-child),
  .markdown-content table:not(.stock-table) tbody td:not(:last-child) {
    border-right: 1px solid #e2e8f0;
  }
  /* テーブルキャプション */
  .markdown-content table caption {
    caption-side: top;
    text-align: left;
    font-size: 0.82rem;
    font-weight: 600;
    color: #64748b;
    padding: 0.4rem 0.5rem 0.4rem 0;
    margin-bottom: 0.25rem;
  }

  /* ===== コードブロック ===== */
  .code-block-wrapper {
    margin: 1.5rem 0.75rem 2rem;
    border-radius: 0.5rem;
    overflow: hidden;
    background: #000;
  }
  .code-block-wrapper pre {
    margin: 0 !important;
    border-radius: 0 !important;
    background: #000 !important;
  }
  .code-block-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.55rem 0.85rem;
    background: #000;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  .code-block-lang {
    font-size: 0.78rem;
    font-weight: 600;
    color: #e2e8f0;
    font-family: 'Inter', ui-sans-serif, sans-serif;
    letter-spacing: 0.02em;
    text-transform: capitalize;
    user-select: none;
  }
  .code-block-actions {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .code-action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    background: transparent;
    border: none;
    border-radius: 4px;
    color: #94a3b8;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    padding: 0;
  }
  .code-action-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #e2e8f0;
  }
  .code-action-btn.copied {
    color: #4ade80;
  }
</style>
<script>
document.addEventListener('DOMContentLoaded', () => {
  // ===== コードブロック =====
  document.querySelectorAll('.markdown-content pre').forEach((pre) => {
    if (pre.parentElement?.classList.contains('code-block-wrapper')) return;

    const codeEl = pre.querySelector('code');
    const lang = pre.getAttribute('data-language') || 'code';

    const wrapper = document.createElement('div');
    wrapper.className = 'code-block-wrapper';
    pre.parentNode.insertBefore(wrapper, pre);
    wrapper.appendChild(pre);

    const header = document.createElement('div');
    header.className = 'code-block-header';
    header.innerHTML = `
      <span class="code-block-lang">${lang}</span>
      <div class="code-block-actions">
        <button class="code-action-btn download-btn" aria-label="ダウンロード">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
        </button>
        <button class="code-action-btn copy-btn" aria-label="コードをコピー">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
        </button>
      </div>
    `;
    wrapper.insertBefore(header, pre);

    header.querySelector('.download-btn').addEventListener('click', () => {
      const text = (codeEl ?? pre).innerText;
      const blob = new Blob([text], { type: 'text/plain' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `code.${lang}`;
      a.click();
      URL.revokeObjectURL(url);
    });

    header.querySelector('.copy-btn').addEventListener('click', async () => {
      const text = (codeEl ?? pre).innerText;
      try {
        await navigator.clipboard.writeText(text);
        const btn = header.querySelector('.copy-btn');
        btn.classList.add('copied');
        setTimeout(() => btn.classList.remove('copied'), 2000);
      } catch { /* clipboard未対応環境は無視 */ }
    });
  });
  // テーブルに caption を自動付与（直前の見出しをキャプションとして使用）
  document.querySelectorAll('.markdown-content table').forEach(table => {
    if (table.querySelector('caption')) return;
    // テーブルの直前の兄弟要素を遡って見出しを探す
    let el = table.previousElementSibling;
    while (el) {
      if (/^H[2-4]$/.test(el.tagName)) {
        const caption = document.createElement('caption');
        caption.textContent = el.textContent.replace(/^[#\s]+/, '').trim();
        table.insertBefore(caption, table.firstChild);
        break;
      }
      // 別の table や paragraph を超えたら探索を止める
      if (el.tagName === 'TABLE' || el.tagName === 'HR') break;
      el = el.previousElementSibling;
    }
  });

  // async を追加して非同期処理（API通信）ができるようにします
  document.querySelectorAll('.book-item img').forEach(async (img) => {
    const item = img.closest('.book-item');
    const isbn = item?.dataset?.isbn || '';

    // 🌟 追加：Google Books APIから画像を動的に取得して差し替える処理
    if (isbn) {
      try {
        const res = await fetch(`https://www.googleapis.com/books/v1/volumes?q=isbn:${isbn}`);
        const data = await res.json();
        // Google Booksに画像が存在した場合、そのURLに上書きする
        if (data.items && data.items.length > 0 && data.items[0].volumeInfo.imageLinks) {
          const googleImgUrl = data.items[0].volumeInfo.imageLinks.thumbnail.replace('http:', 'https:');
          img.src = googleImgUrl; 
        }
      } catch (error) {
        console.error('Google Books APIの取得に失敗しました:', error);
      }
    }

    // 既存のエラーフォールバック処理（万が一Googleの画像も取得失敗した時の保険としてそのまま残します）
    img.addEventListener('error', function onErr() {
      img.removeEventListener('error', onErr);
      if (isbn) {
        const openBDUrl = `https://cover.openbd.jp/${isbn}.jpg`;
        if (img.src !== openBDUrl) {
          img.addEventListener('error', function onErr2() {
            img.removeEventListener('error', onErr2);
            // 最終手段: テキストSVGプレースホルダー
            const short = (img.alt || 'Book').slice(0, 8);
            const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="110" height="155" viewBox="0 0 110 155"><rect width="110" height="155" fill="#1e293b"/><rect x="4" y="4" width="102" height="147" fill="none" stroke="#475569" stroke-width="1"/><text x="55" y="82" font-family="sans-serif" font-size="9" fill="#e2e8f0" text-anchor="middle" dominant-baseline="middle">${short}</text></svg>`;
            img.src = 'data:image/svg+xml;charset=utf-8,' + encodeURIComponent(svg);
            img.style.opacity = '0.7';
          });
          img.src = openBDUrl;
          return;
        }
      }
      // ISBNなし or openBD自体が失敗 → SVGプレースホルダー
      const short = (img.alt || 'Book').slice(0, 8);
      const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="110" height="155" viewBox="0 0 110 155"><rect width="110" height="155" fill="#1e293b"/><rect x="4" y="4" width="102" height="147" fill="none" stroke="#475569" stroke-width="1"/><text x="55" y="82" font-family="sans-serif" font-size="9" fill="#e2e8f0" text-anchor="middle" dominant-baseline="middle">${short}</text></svg>`;
      img.src = 'data:image/svg+xml;charset=utf-8,' + encodeURIComponent(svg);
      img.style.opacity = '0.7';
    });
  });
});
</script>
