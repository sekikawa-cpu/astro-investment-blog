---
import { getCollection } from 'astro:content';

const googleAnalyticsId = import.meta.env.PUBLIC_GOOGLE_ANALYTICS_ID || 'G-7WDEFXG48Y';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  const publishedEntries = blogEntries.filter(e => !e.data.draft);
  return publishedEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry, allEntries: publishedEntries },
  }));
}

const { entry, allEntries } = Astro.props;
const { Content } = await entry.render();
const { title, pubDate, description, tags = [], author, category, pillar, noindex = false, heroImage } = entry.data;

const pillarEmoji = pillar === '投資' ? '📊' : pillar === 'ビジネス・AI・DX' ? '💼' : pillar === '心理学' ? '🧠' : '';

const relatedPosts = allEntries
  .filter(e => e.data.category === category && e.slug !== entry.slug && !e.data.draft)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);

const fullUrl = `https://tech-wealth-mind.com/blog/${entry.slug}/`;
const ogImageUrl = heroImage
  ? `https://tech-wealth-mind.com${heroImage}`
  : 'https://tech-wealth-mind.com/images/profile.png';

const schemaData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "image": ogImageUrl,
  "datePublished": new Date(pubDate).toISOString(),
  "dateModified": entry.data.updatedDate
    ? new Date(entry.data.updatedDate).toISOString()
    : new Date(pubDate).toISOString(),
  "author": {
    "@type": "Person",
    "name": author || "ただの会社員",
    "url": "https://tech-wealth-mind.com/about/"
  },
  "publisher": {
    "@type": "Organization",
    "name": "会社員の生活日記",
    "url": "https://tech-wealth-mind.com/",
    "logo": {
      "@type": "ImageObject",
      "url": "https://tech-wealth-mind.com/images/profile.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": fullUrl
  },
  "url": fullUrl,
  "articleSection": category,
  "keywords": tags.join(", ")
};

const PILLAR_URLS: Record<string, string> = {
  '投資': '/category/toshi/',
  'ビジネス・AI・DX': '/category/business-ai-dx/',
  '心理学': '/category/shinrigaku/',
};
const CATEGORY_URLS: Record<string, string> = {
  // 投資サブカテゴリ（専用ページあり）
  'キーワード解説': '/category/toshi/keyword/',
  '資産運用':       '/category/toshi/shisan-unyo/',
  'コラム':         '/category/toshi/column/',
  // 投資サブカテゴリ（ピラーページへ）
  'マーケット分析': '/category/toshi/',
  '投資戦略':       '/category/toshi/',
  '経済ニュース':   '/category/toshi/',
  '初心者ガイド':   '/category/toshi/',
  '用語・基礎知識': '/category/toshi/',
  '銘柄分析':       '/category/toshi/',
  'ファンド・ETF':  '/category/toshi/',
  // AI/DXサブカテゴリ（専用ページあり）
  'AIツール':       '/category/business-ai-dx/ai-tools/',
  'DX・業務改善':   '/category/business-ai-dx/dx-kaizen/',
  '資格・学習':     '/category/business-ai-dx/shikaku/',
  '書籍レビュー':   '/category/business-ai-dx/books/',
  // AI/DXサブカテゴリ（ピラーページへ）
  'AI最新情報':     '/category/business-ai-dx/',
  // 心理学サブカテゴリ（専用ページあり）
  '心理学・メンタル': '/category/shinrigaku/mental/',
  'ボランティア':     '/category/shinrigaku/volunteer/',
  // 心理学サブカテゴリ（ピラーページへ）
  '生きづらさと回復': '/category/shinrigaku/',
};
const pillarUrl = pillar ? (PILLAR_URLS[pillar] ?? '/') : '/';
const categoryUrl = category ? (CATEGORY_URLS[category] ?? pillarUrl) : pillarUrl;
const breadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://tech-wealth-mind.com/" },
    { "@type": "ListItem", "position": 2, "name": category || pillar || "記事", "item": `https://tech-wealth-mind.com${categoryUrl}` },
    { "@type": "ListItem", "position": 3, "name": title, "item": fullUrl }
  ]
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>{title} | 会社員の生活日記</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="referrer" content="same-origin" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={fullUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- OGP / Twitter Card -->
    <meta property="og:type" content="article" />
    <meta property="og:url" content={fullUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="会社員の生活日記" />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <!-- 構造化データ -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />
    <!-- Google Analytics -->
    {googleAnalyticsId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`}></script>
        <script define:vars={{ googleAnalyticsId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', googleAnalyticsId);
        </script>
      </>
    )}
    <!-- Google AdSense -->
    <meta name="google-adsense-account" content="ca-pub-7499855875738477">
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7499855875738477"
     crossorigin="anonymous"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet" />
  </head>

  <body class="bg-slate-50 text-slate-800 font-sans min-h-screen flex flex-col">
    <header class="site-header">
      <div class="header-container">
        <a href="/" class="logo">
          会社員の生活日記<span class="logo-dot">.</span>
        </a>
        <nav class="cat-nav">
          <a href="/category/ai-dx/" class="cat-nav-link">🤖 AI/DX</a>
          <a href="/category/shikaku/" class="cat-nav-link">📖 資格・学習</a>
          <a href="/category/shigoto/" class="cat-nav-link">💼 仕事術</a>
          <a href="/for-beginners/" class="cat-nav-link cat-nav-link--highlight">✨ 初めての方へ</a>
        </nav>
        <div class="menu-wrapper">
          <div class="page-links">
            <a href="/about/" class="page-link">プロフィール</a>
            <a href="/contact/" class="page-link">お問い合わせ</a>
            <a href="/privacy/" class="page-link">プライバシーポリシー</a>
            <a href="/disclaimer/" class="page-link">免責事項</a>
            <a href="/sitemap/" class="page-link">サイトマップ</a>
          </div>
          <button id="menu-toggle" class="menu-button" aria-label="メニュー">
            <svg id="icon-hamburger" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
            <svg id="icon-close" class="art-hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
          <nav id="nav-menu" class="nav-menu">
            <div class="nav-section-label">カテゴリ</div>
            <ul class="nav-list">
              <li><a href="/" class="nav-link">🏠 ホーム</a></li>
              <li><a href="/category/ai-dx/" class="nav-link">🤖 AI/DX</a></li>
              <li><a href="/category/shikaku/" class="nav-link">📖 資格・学習</a></li>
              <li><a href="/category/shigoto/" class="nav-link">💼 仕事術</a></li>
              <li><a href="/for-beginners/" class="nav-link">✨ 初めての方へ</a></li>
            </ul>
            <div class="nav-divider"></div>
            <div class="nav-section-label">サイト情報</div>
            <ul class="nav-list">
              <li><a href="/about/" class="nav-link">プロフィール</a></li>
              <li><a href="/contact/" class="nav-link">お問い合わせ</a></li>
              <li><a href="/privacy/" class="nav-link">プライバシーポリシー</a></li>
              <li><a href="/disclaimer/" class="nav-link">免責事項</a></li>
              <li><a href="/sitemap/" class="nav-link">サイトマップ</a></li>
            </ul>
          </nav>
        </div>
      </div>
    </header>

    <main class="flex-grow max-w-5xl mx-auto px-4 py-10 w-full">
      <nav aria-label="パンくずリスト" class="mb-4">
        <ol class="flex flex-wrap items-center gap-1 text-xs text-slate-500">
          <li><a href="/" class="hover:text-blue-600 transition-colors">ホーム</a></li>
          {pillar && (
            <>
              <li class="text-slate-300" aria-hidden="true">›</li>
              <li>
                <a href={pillarUrl} class="hover:text-blue-600 transition-colors">
                  {pillarEmoji} {pillar}
                </a>
              </li>
            </>
          )}
          {category && category !== pillar && (
            <>
              <li class="text-slate-300" aria-hidden="true">›</li>
              <li>
                <a href={categoryUrl} class="hover:text-blue-600 transition-colors">
                  {category}
                </a>
              </li>
            </>
          )}
          <li class="text-slate-300" aria-hidden="true">›</li>
          <li class="text-slate-700 font-medium line-clamp-1 max-w-[200px] md:max-w-xs" aria-current="page">{title}</li>
        </ol>
      </nav>

      <article class="bg-white shadow-sm rounded-lg overflow-hidden">
        <header class="px-6 md:px-12 pt-10 pb-8 border-b border-slate-100">
          <div class="flex flex-wrap items-center gap-3 mb-4">
            {category && (
              <span class="bg-blue-100 text-blue-700 text-xs font-bold px-3 py-1 rounded-full">
                {category}
              </span>
            )}
            <p class="text-sm text-blue-600 font-bold">
              {new Date(pubDate).toLocaleDateString('ja-JP', {
                year: 'numeric', month: 'long', day: 'numeric'
              })}
            </p>
          </div>
          <h1 class="text-2xl md:text-3xl font-extrabold text-slate-900 leading-tight">
            {title}
          </h1>
          {author && (
            <p class="text-sm text-slate-500 mt-4">執筆: {author}</p>
          )}
        </header>

        {category === '生きづらさと回復' ? (
          <div class="content-warning mx-6 md:mx-12 mt-6">
            <div class="content-warning-header">
              <span>📢</span>
              <strong>コンテンツ警告</strong>
            </div>
            <p class="content-warning-body">※本記事には家庭内の困難な経験に関する記述が含まれます。回復プロセスを共有する目的で執筆しています。</p>
          </div>
        ) : pillar === '投資' ? (
          <div class="article-disclaimer article-disclaimer--invest article-disclaimer--top mx-6 md:mx-12 mt-6">
            <div class="article-disclaimer__header">
              <span>⚠️</span>
              <strong>投資に関する重要な免責事項</strong>
            </div>
            <p>本記事は情報提供・教育目的です。<strong>特定銘柄の購入・売却を推奨するものではありません。</strong>投資にはリスクが伴い、元本を割り込む可能性があります。投資判断は必ずご自身の責任で行ってください。</p>
          </div>
        ) : null}

        {heroImage && (
          <div class="w-full">
            <img src={heroImage} alt={title} class="w-full h-auto object-cover" />
          </div>
        )}

        <div class="markdown-content px-6 md:px-12 py-10">
          <Content />
        </div>

        {tags.length > 0 && (
          <div class="px-6 md:px-12 pb-8 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="bg-slate-100 text-slate-700 text-xs px-3 py-1 rounded-full">
                #{tag}
              </span>
            ))}
          </div>
        )}

        {relatedPosts.length > 0 && (
          <div class="px-6 md:px-12 py-8 border-t border-slate-100">
            <h2 class="text-sm font-bold text-slate-600 mb-4 flex items-center gap-1">
              <span>📌</span> あわせて読みたい
            </h2>
            <ul class="flex flex-col gap-2">
              {relatedPosts.map(post => (
                <li>
                  <a
                    href={`/blog/${post.slug}/`}
                    class="flex items-center gap-3 p-3 rounded-lg border border-slate-100 hover:border-blue-200 hover:bg-slate-50 transition-colors group"
                  >
                    {post.data.heroImage ? (
                      <img
                        src={post.data.heroImage}
                        alt={post.data.title}
                        class="w-14 h-10 object-cover rounded flex-shrink-0"
                      />
                    ) : (
                      <div class="w-14 h-10 bg-slate-100 rounded flex-shrink-0 flex items-center justify-center text-slate-400 text-xs">
                        📄
                      </div>
                    )}
                    <div class="min-w-0">
                      <span class="text-xs text-slate-400 block mb-0.5">
                        {new Date(post.data.pubDate).toLocaleDateString('ja-JP', { year: 'numeric', month: 'short', day: 'numeric' })}
                      </span>
                      <span class="text-sm font-semibold text-slate-800 group-hover:text-blue-600 transition-colors leading-snug line-clamp-2">
                        {post.data.title}
                      </span>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        {pillar === '投資' && (
          <div class="article-disclaimer article-disclaimer--invest px-6 md:px-12 pb-6">
            <div class="article-disclaimer__header">
              <span>⚠️</span>
              <strong>投資に関する免責事項</strong>
            </div>
            <p>本記事は筆者個人の投資記録であり、特定銘柄の売買を推奨するものではありません。掲載情報は執筆時点のものであり、最新情報は各自でご確認ください。投資判断はご自身の責任で行ってください。</p>
          </div>
        )}

        {pillar === '心理学' && (
          <div class="article-disclaimer article-disclaimer--health px-6 md:px-12 pb-6">
            <div class="article-disclaimer__header">
              <span>🩺</span>
              <strong>医療・専門家への相談について</strong>
            </div>
            <p>本記事は筆者個人の学習記録および体験をもとにした情報提供を目的としています。医療行為や治療の代替となるものではありません。心理的な課題や体調不良については、医師・臨床心理士・カウンセラーなど専門家へのご相談をお勧めします。</p>
          </div>
        )}

        <div class="px-6 md:px-12 pb-10 pt-6 border-t border-slate-100 text-center">
          <a id="article-back-btn" href="/search"
             class="inline-block bg-slate-800 hover:bg-slate-700 text-white font-bold px-8 py-3 rounded-full transition-colors text-sm">
            📰 記事一覧に戻る
          </a>
        </div>
      </article>
    </main>

    <footer class="bg-slate-900 text-slate-400 text-center py-8 mt-auto">
      <p class="text-sm">&copy; 2026 会社員の生活日記. All rights reserved.</p>
      <nav class="flex justify-center gap-6 mt-3 text-xs flex-wrap">
        <a href="/about/" class="hover:text-blue-300 transition-colors">運営者について</a>
        <a href="/contact/" class="hover:text-blue-300 transition-colors">お問い合わせ</a>
        <a href="/privacy/" class="hover:text-blue-300 transition-colors">プライバシーポリシー</a>
      </nav>
    </footer>
  </body>
</html>

<style is:global>
  /* ===== サイトヘッダー（BaseLayout と共通） ===== */
  .site-header {
    height: 70px;
    background: #0f172a;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
    position: sticky;
    top: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
  }
  .header-container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .logo {
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 800;
    color: #ffffff;
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 0.15s;
  }
  .logo:hover { color: #93c5fd; }
  .logo-dot { color: #60a5fa; }
  .cat-nav {
    display: none;
    align-items: center;
    gap: 0.15rem;
    flex: 1;
    padding: 0 0.75rem;
  }
  @media (min-width: 900px) { .cat-nav { display: flex; } }
  .cat-nav-link {
    padding: 0.35rem 0.6rem;
    border-radius: 6px;
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 600;
    color: rgba(255,255,255,0.8);
    white-space: nowrap;
    transition: background 0.15s, color 0.15s;
  }
  .cat-nav-link:hover { background: rgba(255,255,255,0.12); color: #ffffff; }
  .cat-nav-link--highlight { background: #3b82f6; color: #ffffff; }
  .cat-nav-link--highlight:hover { background: #2563eb; color: #ffffff; }
  .menu-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }
  .page-links {
    display: none;
    align-items: center;
    gap: 0.1rem;
  }
  @media (min-width: 900px) { .page-links { display: flex; } }
  .page-link {
    padding: 0.3rem 0.5rem;
    text-decoration: none;
    font-size: 0.78rem;
    color: rgba(255,255,255,0.65);
    font-weight: 500;
    border-radius: 4px;
    white-space: nowrap;
    transition: color 0.15s, background 0.15s;
  }
  .page-link:hover { color: #ffffff; background: rgba(255,255,255,0.1); }
  .menu-button {
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 6px;
    padding: 8px;
    cursor: pointer;
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }
  @media (min-width: 900px) { .menu-button { display: none; } }
  .menu-button:hover { background: rgba(255,255,255,0.2); }
  .art-hidden { display: none; }
  .nav-menu {
    position: absolute;
    top: calc(100% + 12px);
    right: 0;
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
    min-width: 240px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: all 0.2s ease;
    z-index: 1001;
  }
  .nav-menu.is-active { opacity: 1; visibility: visible; transform: translateY(0); }
  .nav-section-label {
    padding: 8px 16px 4px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #94a3b8;
  }
  .nav-divider { height: 1px; background: #e2e8f0; margin: 4px 0; }
  .nav-list { list-style: none; padding: 4px 0; margin: 0; }
  .nav-link {
    display: block;
    padding: 10px 20px;
    text-decoration: none;
    color: #2d3748;
    font-size: 0.9rem;
    font-weight: 500;
  }
  .nav-link:hover { background-color: #f7fafc; color: #3182ce; }

  /* ===== 記事末尾免責ブロック ===== */
  .article-disclaimer {
    margin: 0 0 1rem;
    padding: 1rem 1.25rem;
    border-radius: 0 0.5rem 0.5rem 0;
    font-size: 0.84rem;
    line-height: 1.75;
  }
  .article-disclaimer__header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    font-size: 0.88rem;
  }
  .article-disclaimer p { margin: 0; }
  .article-disclaimer--invest {
    background: linear-gradient(135deg, #fff1f2 0%, #ffe4e6 100%);
    border: 1px solid #f87171;
    border-left: 5px solid #dc2626;
    border-radius: 0 0.5rem 0.5rem 0;
    color: #7f1d1d;
  }
  .article-disclaimer--invest .article-disclaimer__header { color: #991b1b; }
  .article-disclaimer--invest strong { color: #7f1d1d; font-weight: 700; }
  .article-disclaimer--top { margin-bottom: 0; }
  .article-disclaimer--health {
    background: #f0f9ff;
    border-left: 4px solid #38bdf8;
    color: #0c4a6e;
  }
  .article-disclaimer--health .article-disclaimer__header { color: #0369a1; }

  /* ===== この記事でわかること ===== */
  .markdown-content .article-summary {
    margin: 0 0 2rem;
    padding: 1.25rem 1.5rem;
