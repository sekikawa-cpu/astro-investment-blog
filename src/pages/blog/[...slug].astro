---
import { getCollection } from 'astro:content';

// 1. 全記事のパスを生成
export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

// 2. 記事データの取得
const { entry } = Astro.props;
const { Content } = await entry.render();
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>{entry.data.title} | 配当＆優待ナビ</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content={entry.data.description} />
  </head>
  <body class="bg-slate-50 text-slate-800 font-sans min-h-screen flex flex-col">
    <header class="bg-slate-900 text-white shadow-md py-4">
      <div class="max-w-4xl mx-auto px-4 flex justify-between items-center">
        <a href="/" class="text-xl md:text-2xl font-bold tracking-wider hover:text-blue-300 transition-colors">配当＆優待ナビ 💸</a>
        <a href="/" class="text-sm text-slate-300 hover:underline">一覧に戻る</a>
      </div>
    </header>

    <main class="flex-grow max-w-4xl mx-auto px-4 py-10 w-full bg-white shadow-sm my-6 rounded-lg">
      <article class="prose prose-slate max-w-none">
        <header class="mb-8 border-b pb-6">
          <p class="text-blue-600 font-bold mb-2">
            {new Date(entry.data.pubDate).toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
          </p>
          <h1 class="text-3xl md:text-4xl font-extrabold text-slate-900 leading-tight">
            {entry.data.title}
          </h1>
          <div class="mt-4 flex flex-wrap gap-2">
            {entry.data.tags.map((tag: string) => (
              <span class="bg-slate-100 text-slate-600 text-xs px-2 py-1 rounded">#{tag}</span>
            ))}
          </div>
        </header>

        <div class="markdown-content">
          <Content />
        </div>
      </article>
    </main>

    <footer class="bg-slate-900 text-slate-400 text-center py-8 mt-auto">
      <p class="text-sm">&copy; 2026 配当＆優待ナビ. All rights reserved.</p>
    </footer>
  </body>
</html>

<style is:global>
  /* 記事本文内のMarkdown要素のスタイル調整 */
  .markdown-content h2 {
    @apply text-2xl font-bold text-slate-800 mt-12 mb-6 border-l-4 border-blue-600 pl-4;
  }
  .markdown-content h3 {
    @apply text-xl font-bold text-slate-800 mt-8 mb-4;
  }
  .markdown-content p {
    @apply leading-relaxed mb-6 text-slate-700;
  }

  /* --- テーブルのカスタマイズ（縞々・右揃え） --- */
  .markdown-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.9rem;
    display: block;
    overflow-x: auto; /* スマホで見切れないように横スクロール許可 */
  }
  .markdown-content th {
    background-color: #1e293b; /* ダークな紺色 */
    color: white;
    padding: 12px;
    font-weight: bold;
    text-align: center;
    border: 1px solid #334155;
  }
  .markdown-content td {
    padding: 12px;
    border-bottom: 1px solid #e2e8f0;
    color: #334155;
  }
  
  /* 奇数・偶数行の色分け（ゼブラストライプ） */
  .markdown-content tr:nth-child(even) {
    background-color: #f8fafc;
  }

  /* マウスホバーで強調 */
  .markdown-content tr:hover {
    background-color: #f1f5f9;
  }

  /* Python側で指定した :---: (右揃え) などを適用 */
  .markdown-content td:nth-child(4),
  .markdown-content td:nth-child(5),
  .markdown-content td:nth-child(6) {
    text-align: right;
    font-family: 'Courier New', Courier, monospace; /* 数値を揃えやすくする */
  }
  .markdown-content td:nth-child(1),
  .markdown-content td:nth-child(3) {
    text-align: center;
  }

  /* 免責事項を控えめにする */
  small {
    display: block;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px dashed #cbd5e1;
    line-height: 1.6;
    font-size: 0.8rem;
    color: #94a3b8 !important;
  }

  /* おすすめ書籍セクションの微調整 */
  .markdown-content ul {
    @apply list-none p-0;
  }
  .markdown-content li {
    @apply mb-4 p-4 bg-blue-50 rounded-lg border border-blue-100;
  }
</style>
