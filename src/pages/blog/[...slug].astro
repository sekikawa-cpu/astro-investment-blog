  }

  /* ===== コードブロック ===== */
  .code-block-wrapper {
    margin: 1.5rem 0.75rem 2rem;
    border-radius: 0.5rem;
    overflow: hidden;
    background: #000;
  }
  .code-block-wrapper pre {
    margin: 0 !important;
    border-radius: 0 !important;
    background: #000 !important;
    padding: 1rem 1.25rem 1.5rem !important;
  }
  .code-block-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.55rem 0.85rem;
    background: #000;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  .code-block-lang {
    font-size: 0.78rem;
    font-weight: 600;
    color: #e2e8f0;
    font-family: 'Inter', ui-sans-serif, sans-serif;
    letter-spacing: 0.02em;
    text-transform: capitalize;
    user-select: none;
  }
  .code-block-actions {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .code-action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    background: transparent;
    border: none;
    border-radius: 4px;
    color: #94a3b8;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    padding: 0;
  }
  .code-action-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #e2e8f0;
  }
  .code-action-btn.copied {
    color: #4ade80;
  }
</style>
<script>
document.addEventListener('DOMContentLoaded', () => {
  // ===== コードブロック =====
  document.querySelectorAll('.markdown-content pre').forEach((pre) => {
    if (pre.parentElement?.classList.contains('code-block-wrapper')) return;

    const codeEl = pre.querySelector('code');
    const lang = pre.getAttribute('data-language') || 'code';

    const wrapper = document.createElement('div');
    wrapper.className = 'code-block-wrapper';
    pre.parentNode.insertBefore(wrapper, pre);
    wrapper.appendChild(pre);

    const header = document.createElement('div');
    header.className = 'code-block-header';
    header.innerHTML = `
      <span class="code-block-lang">${lang}</span>
      <div class="code-block-actions">
        <button class="code-action-btn download-btn" aria-label="ダウンロード">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
        </button>
        <button class="code-action-btn copy-btn" aria-label="コードをコピー">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
        </button>
      </div>
    `;
    wrapper.insertBefore(header, pre);

    header.querySelector('.download-btn').addEventListener('click', () => {
      const text = (codeEl ?? pre).innerText;
      const blob = new Blob([text], { type: 'text/plain' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `code.${lang}`;
      a.click();
      URL.revokeObjectURL(url);
    });

    header.querySelector('.copy-btn').addEventListener('click', async () => {
      const text = (codeEl ?? pre).innerText;
      try {
        await navigator.clipboard.writeText(text);
        const btn = header.querySelector('.copy-btn');
        btn.classList.add('copied');
        setTimeout(() => btn.classList.remove('copied'), 2000);
      } catch { /* clipboard未対応環境は無視 */ }
    });
  });
  // テーブルに caption を自動付与（直前の見出しをキャプションとして使用）
  document.querySelectorAll('.markdown-content table').forEach(table => {
    if (table.querySelector('caption')) return;
    // テーブルの直前の兄弟要素を遡って見出しを探す
    let el = table.previousElementSibling;
    while (el) {
      if (/^H[2-4]$/.test(el.tagName)) {
        const caption = document.createElement('caption');
        caption.textContent = el.textContent.replace(/^[#\s]+/, '').trim();
        table.insertBefore(caption, table.firstChild);
        break;
      }
      // 別の table や paragraph を超えたら探索を止める
      if (el.tagName === 'TABLE' || el.tagName === 'HR') break;
      el = el.previousElementSibling;
    }
  });

  // async を追加して非同期処理（API通信）ができるようにします
  document.querySelectorAll('.book-item img').forEach(async (img) => {
    const item = img.closest('.book-item');
    const isbn = item?.dataset?.isbn || '';

    // 🌟 追加：Google Books APIから画像を動的に取得して差し替える処理
    if (isbn) {
      try {
        const res = await fetch(`https://www.googleapis.com/books/v1/volumes?q=isbn:${isbn}`);
        const data = await res.json();
        // Google Booksに画像が存在した場合、そのURLに上書きする
        if (data.items && data.items.length > 0 && data.items[0].volumeInfo.imageLinks) {
          const googleImgUrl = data.items[0].volumeInfo.imageLinks.thumbnail.replace('http:', 'https:');
          img.src = googleImgUrl; 
        }
      } catch (error) {
        console.error('Google Books APIの取得に失敗しました:', error);
      }
    }

    // 既存のエラーフォールバック処理（万が一Googleの画像も取得失敗した時の保険としてそのまま残します）
    img.addEventListener('error', function onErr() {
      img.removeEventListener('error', onErr);
      if (isbn) {
        const openBDUrl = `https://cover.openbd.jp/${isbn}.jpg`;
        if (img.src !== openBDUrl) {
          img.addEventListener('error', function onErr2() {
            img.removeEventListener('error', onErr2);
            // 最終手段: テキストSVGプレースホルダー
            const short = (img.alt || 'Book').slice(0, 8);
            const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="110" height="155" viewBox="0 0 110 155"><rect width="110" height="155" fill="#1e293b"/><rect x="4" y="4" width="102" height="147" fill="none" stroke="#475569" stroke-width="1"/><text x="55" y="82" font-family="sans-serif" font-size="9" fill="#e2e8f0" text-anchor="middle" dominant-baseline="middle">${short}</text></svg>`;
            img.src = 'data:image/svg+xml;charset=utf-8,' + encodeURIComponent(svg);
            img.style.opacity = '0.7';
          });
          img.src = openBDUrl;
          return;
        }
      }
      // ISBNなし or openBD自体が失敗 → SVGプレースホルダー
      const short = (img.alt || 'Book').slice(0, 8);
      const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="110" height="155" viewBox="0 0 110 155"><rect width="110" height="155" fill="#1e293b"/><rect x="4" y="4" width="102" height="147" fill="none" stroke="#475569" stroke-width="1"/><text x="55" y="82" font-family="sans-serif" font-size="9" fill="#e2e8f0" text-anchor="middle" dominant-baseline="middle">${short}</text></svg>`;
      img.src = 'data:image/svg+xml;charset=utf-8,' + encodeURIComponent(svg);
      img.style.opacity = '0.7';
    });
  });
});
</script>

<script>
  // 記事フッターの戻るボタン：前ページに応じて切り替え
  (function() {
    const btn = document.getElementById('article-back-btn');
    if (!btn) return;
    const ref = document.referrer;
    const origin = location.origin;
    if (ref && ref.startsWith(origin)) {
      const refPath = ref.slice(origin.length).split('?')[0];
      if (refPath === '/' || refPath === '') {
        btn.textContent = '🏠 トップページに戻る';
        btn.setAttribute('href', '/');
      } else {
        btn.textContent = '📰 記事一覧に戻る';
        btn.setAttribute('href', ref);
      }
    }
  })();
</script>

<script>
  // ヘッダーハンバーガーメニュー
  (function() {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('nav-menu');
    const iconHam = document.getElementById('icon-hamburger');
    const iconClose = document.getElementById('icon-close');
    if (!toggle || !menu) return;
    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      menu.classList.toggle('is-active');
      iconHam?.classList.toggle('art-hidden');
      iconClose?.classList.toggle('art-hidden');
    });
    document.addEventListener('click', (e) => {
      if (!menu.contains(e.target) && !toggle.contains(e.target)) {
        menu.classList.remove('is-active');
        iconHam?.classList.remove('art-hidden');
        iconClose?.classList.add('art-hidden');
      }
    });
  })();
</script>
