---
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>{entry.data.title} | 配当＆優待ナビ</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content={entry.data.description} />
  </head>
  <body class="bg-slate-50 text-slate-800 font-sans min-h-screen flex flex-col">
    <header class="bg-slate-900 text-white shadow-md py-4">
      <div class="max-w-5xl mx-auto px-4 flex justify-between items-center">
        <a href="/" class="text-xl md:text-2xl font-bold tracking-wider hover:text-blue-300">配当＆優待ナビ 💸</a>
        <a href="/" class="text-sm text-slate-300 hover:underline">一覧に戻る</a>
      </div>
    </header>

    <main class="flex-grow max-w-5xl mx-auto px-4 py-10 w-full bg-white shadow-sm my-6 rounded-lg">
      <article class="prose prose-slate max-w-none">
        <header class="mb-8 border-b pb-6">
          <p class="text-blue-600 font-bold mb-2">{new Date(entry.data.pubDate).toLocaleDateString('ja-JP')}</p>
          <h1 class="text-2xl md:text-3xl font-extrabold text-slate-900 leading-tight">
            {entry.data.title}
          </h1>
        </header>

        <div class="markdown-content">
          <Content />
        </div>
      </article>
    </main>

    <footer class="bg-slate-900 text-slate-400 text-center py-8 mt-auto">
      <p class="text-sm">&copy; 2026 配当＆優待ナビ. All rights reserved.</p>
    </footer>
  </body>
</html>

<style is:global>
  /* 基本フォント設定 */
  .markdown-content { @apply text-slate-700; }
  
  /* 解説セクションの見出し */
  .markdown-content h2 { @apply text-2xl font-bold text-slate-800 mt-12 mb-6 border-l-4 border-blue-600 pl-4; }
  .markdown-content h3 { @apply text-xl font-bold text-blue-700 mt-10 mb-2 border-b-2 border-blue-100 pb-1; }
  
  /* 解説本文の改行後の余白 */
  .markdown-content h3 + p { @apply mt-4 mb-8; }

  /* --- テーブルのカスタマイズ（フォント拡大・右揃え） --- */
  .markdown-content table {
    @apply w-full border-collapse my-8;
    display: table;
    font-size: 1rem; /* テーブル内のフォントを少し大きく */
  }
  
  .markdown-content th {
    @apply bg-slate-800 text-white p-3 font-bold text-xs text-center border border-slate-700;
  }
  
  .markdown-content td {
    @apply p-3 border-b border-slate-200 text-slate-700;
  }
  
  .markdown-content tr:nth-child(even) { background-color: #f8fafc; }

  /* 右揃え（標準フォントを使用） */
  .markdown-content td:nth-child(4),
  .markdown-content td:nth-child(5),
  .markdown-content td:nth-child(6),
  .markdown-content td:nth-child(7) {
    text-align: right;
  }
  
  .markdown-content td:nth-child(1),
  .markdown-content td:nth-child(2) {
    text-align: center;
  }

  /* --- 書籍紹介セクション（サムネイル横並び） --- */
  .book-item {
    @apply flex items-center gap-6 mb-6 border-b border-slate-100 pb-6;
  }
  
  .book-item img {
    @apply w-16 h-auto rounded shadow-sm flex-shrink-0 border border-slate-200;
  }
  
  .book-item .book-info { @apply flex-1; }
  
  .book-item strong { @apply text-base text-slate-900 block mb-1; }
  
  .book-item p { @apply text-sm text-slate-500 m-0; }

  /* --- 免責事項（最下部に統合） --- */
  .disclaimer {
    @apply mt-16 pt-8 border-t border-dashed border-slate-300 text-[11px] text-slate-400 leading-relaxed;
  }
</style>
