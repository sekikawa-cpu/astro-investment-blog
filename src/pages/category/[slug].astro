---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  return [
    { params: { slug: 'toshi' } },
    { params: { slug: 'business-ai-dx' } },
    { params: { slug: 'shinrigaku' } },
    { params: { slug: 'keyword-kaisetsu' } },
  ];
}

const PILLAR_MAP: Record<string, {
  label: string;
  icon: string;
  description: string;
  badgeClass: string;
  borderClass: string;
  textClass: string;
  filterByCategory?: string;
}> = {
  'toshi': {
    label: '投資',
    icon: '📊',
    description: '高配当株・新NISA・株主優待の実践記録。長期投資のリアルな記録を綴ります。',
    badgeClass: 'bg-blue-100 text-blue-700',
    borderClass: 'border-blue-500',
    textClass: 'text-blue-600',
  },
  'business-ai-dx': {
    label: 'ビジネス・AI・DX',
    icon: '🤖',
    description: 'AI/DX推進部 副部長として現場で試したツール・施策・資格学習のレポート。',
    badgeClass: 'bg-purple-100 text-purple-700',
    borderClass: 'border-purple-500',
    textClass: 'text-purple-600',
  },
  'shinrigaku': {
    label: '心理学',
    icon: '🧠',
    description: '産業カウンセラー養成講座修了の知見をもとに、メンタルヘルス・生きづらさの回復をテーマにした記事。',
    badgeClass: 'bg-teal-100 text-teal-700',
    borderClass: 'border-teal-500',
    textClass: 'text-teal-600',
  },
  'keyword-kaisetsu': {
    label: 'キーワード解説',
    icon: '📖',
    description: '投資・資産運用・NISA・ETFなど、知っておきたい金融・経済キーワードをわかりやすく解説します。',
    badgeClass: 'bg-orange-100 text-orange-700',
    borderClass: 'border-orange-500',
    textClass: 'text-orange-600',
    filterByCategory: 'キーワード解説',
  },
};

const { slug } = Astro.params;
const pillarInfo = PILLAR_MAP[slug as string]!;

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(p => {
    if (p.data.draft || p.data.noindex) return false;
    if (pillarInfo.filterByCategory) return p.data.category === pillarInfo.filterByCategory;
    return (p.data.pillar ?? '投資') === pillarInfo.label;
  })
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());
---
<BaseLayout
  title={`${pillarInfo.icon} ${pillarInfo.label}の記事一覧`}
  description={pillarInfo.description}
>
  <div class="max-w-4xl mx-auto px-4 py-8">

    <!-- パンくず -->
    <nav class="text-xs text-slate-500 mb-4 flex items-center gap-1">
      <a href="/" class="hover:text-blue-600">ホーム</a>
      <span>›</span>
      <span class={`${pillarInfo.textClass} font-semibold`}>{pillarInfo.label}</span>
    </nav>

    <!-- 見出し -->
    <div class={`border-l-4 ${pillarInfo.borderClass} pl-4 mb-8`}>
      <h1 class="text-2xl font-bold text-slate-900 flex items-center gap-2 flex-wrap">
        <span>{pillarInfo.icon}</span>
        <span class={pillarInfo.textClass}>{pillarInfo.label}</span>
        <span class="text-base font-normal text-slate-500">の記事一覧（{posts.length}件）</span>
      </h1>
      <p class="text-sm text-slate-500 mt-1">{pillarInfo.description}</p>
    </div>

    {posts.length === 0 ? (
      <div class="text-center py-16 text-slate-400">
        <p class="text-4xl mb-4">📝</p>
        <p>近日公開予定です。お楽しみに。</p>
        <a href="/" class="mt-4 inline-block text-blue-600 hover:underline text-sm">← トップに戻る</a>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {posts.map(post => (
          <a href={`/blog/${post.slug}/`}
            class="block bg-white rounded-xl shadow-sm border border-slate-200 hover:shadow-md hover:border-blue-400 hover:-translate-y-0.5 transition-all duration-200 overflow-hidden">
            {post.data.heroImage ? (
              <img src={post.data.heroImage} alt={post.data.title} class="w-full h-36 object-cover" />
            ) : (
              <div class="w-full h-36 bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center">
                <span class="text-5xl opacity-20">{pillarInfo.icon}</span>
              </div>
            )}
            <div class="p-5">
              <div class="flex items-center gap-2 mb-2">
                <span class={`text-xs font-bold px-2 py-0.5 rounded-full ${pillarInfo.badgeClass}`}>
                  {post.data.category}
                </span>
                <span class="text-xs text-slate-400">
                  {new Date(post.data.pubDate).toLocaleDateString('ja-JP')}
                </span>
              </div>
              <h2 class="text-base font-bold text-slate-900 mb-2 leading-snug">{post.data.title}</h2>
              {post.data.description && (
                <p class="text-slate-500 text-xs line-clamp-2 mb-3">{post.data.description}</p>
              )}
              <div class={`text-xs font-semibold ${pillarInfo.textClass}`}>記事を読む →</div>
            </div>
          </a>
        ))}
      </div>
    )}

    <div class="mt-8 text-center">
      <a href="/" class="text-sm text-blue-600 hover:underline">← トップに戻る</a>
    </div>
  </div>
</BaseLayout>
