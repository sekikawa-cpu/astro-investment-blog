---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  return [
    { params: { slug: 'ai-dx' } },
    { params: { slug: 'shikaku' } },
    { params: { slug: 'shigoto' } },
    // 旧URL（toshi・business-ai-dx・shinrigaku・keyword-kaisetsu）は
    // public/_redirects で 301 リダイレクト設定済み
  ];
}

const PILLAR_MAP: Record<string, {
  label: string;
  icon: string;
  description: string;
  longDescription: string;
  badgeClass: string;
  borderClass: string;
  textClass: string;
  bgClass: string;
  filterByCategory?: string;
  filterByCategories?: string[];
  filterByPillar?: string;
}> = {
  // ── 新カテゴリ（3本柱） ──────────────────────────────────────────
  'ai-dx': {
    label: 'AI/DX・生成AI活用',
    icon: '🤖',
    description: 'ChatGPT・Claude・Geminiなど生成AIを実際の業務でどう使ったか、AI/DX推進現場のリアルを発信します。',
    longDescription: 'このカテゴリでは、AI/DX推進部 副部長として実務で活用した生成AIツール・AI最新情報を記録しています。ツールの料金・機能は変更される場合があります。最新情報は各公式サイトでご確認ください。記事内の評価は筆者個人の体験に基づくものです。',
    badgeClass: 'bg-purple-100 text-purple-700',
    borderClass: 'border-purple-500',
    textClass: 'text-purple-600',
    bgClass: 'bg-purple-50 border-purple-200',
    filterByCategories: ['AIツール', 'AI最新情報'],
  },
  'shikaku': {
    label: '資格・学習記録',
    icon: '📖',
    description: 'AI系に限らず、キャリアを切り拓くための資格学習・自己研鑽の全記録。勉強法・詰まった場所・仕事との両立を書いています。',
    longDescription: 'このカテゴリでは、IT・AI・ビジネス・人事など幅広い分野の資格取得体験を記録しています。「合格した」だけでなく、どの教材を使ったか・どこで詰まったか・仕事と両立するためにどう工夫したかまで書いています。',
    badgeClass: 'bg-amber-100 text-amber-700',
    borderClass: 'border-amber-500',
    textClass: 'text-amber-600',
    bgClass: 'bg-amber-50 border-amber-200',
    filterByCategory: '資格・学習',
  },
  'shigoto': {
    label: '仕事術・キャリア形成',
    icon: '💼',
    description: 'DX推進部の副部長として現場で感じた壁や気づき、仕事を切り拓いてきた体験談をお届けします。',
    longDescription: 'このカテゴリでは、DX推進・業務改善の現場体験と、書籍から得た仕事の知見を記録しています。うまくいったことより「こうすれば良かった」という気づきを大切にしています。',
    badgeClass: 'bg-cyan-100 text-cyan-700',
    borderClass: 'border-cyan-500',
    textClass: 'text-cyan-600',
    bgClass: 'bg-cyan-50 border-cyan-200',
    filterByCategories: ['DX・業務改善', '書籍レビュー'],
  },
  // ── 旧カテゴリ（後方互換・記事非公開中） ────────────────────────
  'toshi': {
    label: '投資',
    icon: '📊',
    description: '高配当株・新NISA・株主優待の実践記録。',
    longDescription: '',
    badgeClass: 'bg-blue-100 text-blue-700',
    borderClass: 'border-blue-500',
    textClass: 'text-blue-600',
    bgClass: 'bg-blue-50 border-blue-200',
    filterByPillar: '投資',
  },
  'business-ai-dx': {
    label: 'ビジネス・AI・DX',
    icon: '🤖',
    description: 'AI/DX推進部 副部長として現場で試したツール・施策・資格学習のレポート。',
    longDescription: '',
    badgeClass: 'bg-purple-100 text-purple-700',
    borderClass: 'border-purple-500',
    textClass: 'text-purple-600',
    bgClass: 'bg-purple-50 border-purple-200',
    filterByPillar: 'ビジネス・AI・DX',
  },
  'shinrigaku': {
    label: '心理学',
    icon: '🧠',
    description: '産業カウンセラー養成講座修了の知見をもとにした記事。',
    longDescription: '',
    badgeClass: 'bg-teal-100 text-teal-700',
    borderClass: 'border-teal-500',
    textClass: 'text-teal-600',
    bgClass: 'bg-teal-50 border-teal-200',
    filterByPillar: '心理学',
  },
  'keyword-kaisetsu': {
    label: 'キーワード解説',
    icon: '📖',
    description: '金融・経済キーワードをわかりやすく解説します。',
    longDescription: '',
    badgeClass: 'bg-orange-100 text-orange-700',
    borderClass: 'border-orange-500',
    textClass: 'text-orange-600',
    bgClass: 'bg-orange-50 border-orange-200',
    filterByCategory: 'キーワード解説',
  },
};

const { slug } = Astro.params;
const pillarInfo = PILLAR_MAP[slug as string]!;

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(p => {
    if (p.data.draft || p.data.noindex) return false;
    if (pillarInfo.filterByCategories) return pillarInfo.filterByCategories.includes(p.data.category ?? '');
    if (pillarInfo.filterByCategory) return p.data.category === pillarInfo.filterByCategory;
    if (pillarInfo.filterByPillar) return (p.data.pillar ?? '投資') === pillarInfo.filterByPillar;
    return (p.data.pillar ?? '投資') === pillarInfo.label;
  })
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());
---
<BaseLayout
  title={`${pillarInfo.icon} ${pillarInfo.label}の記事一覧`}
  description={pillarInfo.description}
>
  <div class="max-w-4xl mx-auto px-4 py-8">

    <!-- パンくず -->
    <nav class="text-xs text-slate-500 mb-4 flex items-center gap-1">
      <a href="/" class="hover:text-blue-600">ホーム</a>
      <span>›</span>
      <span class={`${pillarInfo.textClass} font-semibold`}>{pillarInfo.label}</span>
    </nav>

    <!-- 見出し -->
    <div class={`border-l-4 ${pillarInfo.borderClass} pl-4 mb-8`}>
      <h1 class="text-2xl font-bold text-slate-900 flex items-center gap-2 flex-wrap">
        <span>{pillarInfo.icon}</span>
        <span class={pillarInfo.textClass}>{pillarInfo.label}</span>
        <span class="text-base font-normal text-slate-500">の記事一覧（{posts.length}件）</span>
      </h1>
      <p class="text-sm text-slate-500 mt-1">{pillarInfo.description}</p>
    </div>

    {pillarInfo.longDescription && (
      <div class={`text-xs text-slate-600 leading-relaxed p-3 rounded border mb-6 ${pillarInfo.bgClass}`}>
        {pillarInfo.longDescription}
      </div>
    )}

    {posts.length === 0 ? (
      <div class="text-center py-16 text-slate-400">
        <p class="text-4xl mb-4">📝</p>
        <p>近日公開予定です。お楽しみに。</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {posts.map(post => (
          <a href={`/blog/${post.slug}/`}
            class="block bg-white rounded-xl shadow-sm border border-slate-200 hover:shadow-md hover:border-blue-400 hover:-translate-y-0.5 transition-all duration-200 overflow-hidden">
            {post.data.heroImage ? (
              <img src={post.data.heroImage} alt={post.data.title} class="w-full h-36 object-cover" />
            ) : (
              <div class="w-full h-36 bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center">
                <span class="text-5xl opacity-20">{pillarInfo.icon}</span>
              </div>
            )}
            <div class="p-5">
              <div class="flex items-center gap-2 mb-2">
                <span class={`text-xs font-bold px-2 py-0.5 rounded-full ${pillarInfo.badgeClass}`}>
                  {post.data.category}
                </span>
                <span class="text-xs text-slate-400">
                  {new Date(post.data.pubDate).toLocaleDateString('ja-JP')}
                </span>
              </div>
              <h2 class="text-base font-bold text-slate-900 mb-2 leading-snug">{post.data.title}</h2>
              {post.data.description && (
                <p class="text-slate-500 text-xs line-clamp-2 mb-3">{post.data.description}</p>
              )}
              <div class={`text-xs font-semibold ${pillarInfo.textClass}`}>記事を読む →</div>
            </div>
          </a>
        ))}
      </div>
    )}

    <!-- トップページへのリンク -->
    <div class="mt-8 pt-6 border-t border-slate-200 text-center">
      <a href="/" class="inline-block bg-slate-800 hover:bg-slate-700 text-white font-bold px-8 py-3 rounded-full transition-colors text-sm">
        🏠 トップページに戻る
      </a>
    </div>

  </div>
</BaseLayout>
