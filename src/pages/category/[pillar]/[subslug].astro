---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

interface PillarConfig {
  pillarLabel: string;
  pillarIcon: string;
  pillarColor: string;
  borderClass: string;
  badgeClass: string;
  bgClass: string;
}

interface SubcatConfig {
  label: string;
  category: string;
  description: string;
  disclaimer?: string;
}

// getStaticPaths 内で定義し、props 経由で渡すことで
// Astro の getStaticPaths スコープ問題を回避する
export async function getStaticPaths() {
  // 旧サブカテゴリページはすべて public/_redirects で 301 リダイレクト設定済み。
  // 新カテゴリ構造はフラット（/category/ai-dx/ 等）のためサブカテゴリページは不要。
  return [];
}

const { pillar, subslug } = Astro.params;
const { pillarConfig, subcatConfig } = Astro.props as {
  pillarConfig: PillarConfig;
  subcatConfig: SubcatConfig;
};

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(p => !p.data.draft && !p.data.noindex && p.data.category === subcatConfig.category)
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

const canonicalUrl = `https://tech-wealth-mind.com/category/${pillar}/${subslug}/`;
const pillarUrl = `/category/${pillar}/`;

const breadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://tech-wealth-mind.com/" },
    { "@type": "ListItem", "position": 2, "name": pillarConfig.pillarLabel, "item": `https://tech-wealth-mind.com${pillarUrl}` },
    { "@type": "ListItem", "position": 3, "name": subcatConfig.label, "item": canonicalUrl },
  ]
};

const collectionPageData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `${subcatConfig.label}の記事一覧`,
  "description": subcatConfig.description,
  "url": canonicalUrl,
  "isPartOf": {
    "@type": "WebSite",
    "name": "会社員の生活日記",
    "url": "https://tech-wealth-mind.com/"
  }
};
---

<BaseLayout
  title={`${subcatConfig.label}の記事一覧`}
  description={subcatConfig.description}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />
  <script type="application/ld+json" set:html={JSON.stringify(collectionPageData)} />

  <div class="max-w-4xl mx-auto px-4 py-8">

    <!-- パンくずリスト -->
    <nav aria-label="パンくずリスト" class="text-xs text-slate-500 mb-4 flex items-center gap-1 flex-wrap">
      <a href="/" class="hover:text-blue-600 transition-colors">ホーム</a>
      <span aria-hidden="true">›</span>
      <a href={pillarUrl} class={`${pillarConfig.pillarColor} font-semibold hover:underline transition-colors`}>
        {pillarConfig.pillarIcon} {pillarConfig.pillarLabel}
      </a>
      <span aria-hidden="true">›</span>
      <span class="text-slate-700 font-medium" aria-current="page">{subcatConfig.label}</span>
    </nav>

    <!-- 見出し -->
    <div class={`border-l-4 ${pillarConfig.borderClass} pl-4 mb-8`}>
      <h1 class="text-2xl font-bold text-slate-900 flex items-center gap-2 flex-wrap">
        <span>{pillarConfig.pillarIcon}</span>
        <span class={pillarConfig.pillarColor}>{subcatConfig.label}</span>
        <span class="text-base font-normal text-slate-500">の記事一覧（{posts.length}件）</span>
      </h1>
      <p class="text-sm text-slate-500 mt-1">{subcatConfig.description}</p>
    </div>

    {subcatConfig.disclaimer && (
      <div class={`text-xs text-slate-600 leading-relaxed p-3 rounded border mb-6 ${pillarConfig.bgClass}`}>
        {subcatConfig.disclaimer}
      </div>
    )}

    {posts.length === 0 ? (
      <div class="text-center py-16 text-slate-400">
        <p class="text-4xl mb-4">📝</p>
        <p>近日公開予定です。お楽しみに。</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {posts.map(post => (
          <a href={`/blog/${post.slug}/`}
            class="block bg-white rounded-xl shadow-sm border border-slate-200 hover:shadow-md hover:border-blue-400 hover:-translate-y-0.5 transition-all duration-200 overflow-hidden">
            {post.data.heroImage ? (
              <img src={post.data.heroImage} alt={post.data.title} class="w-full h-36 object-cover" />
            ) : (
              <div class="w-full h-36 bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center">
                <span class="text-5xl opacity-20">{pillarConfig.pillarIcon}</span>
              </div>
            )}
            <div class="p-5">
              <div class="flex items-center gap-2 mb-2">
                <span class={`text-xs font-bold px-2 py-0.5 rounded-full ${pillarConfig.badgeClass}`}>
                  {post.data.category}
                </span>
                <span class="text-xs text-slate-400">
                  {new Date(post.data.pubDate).toLocaleDateString('ja-JP')}
                </span>
              </div>
              <h2 class="text-base font-bold text-slate-900 mb-2 leading-snug">{post.data.title}</h2>
              {post.data.description && (
                <p class="text-slate-500 text-xs line-clamp-2 mb-3">{post.data.description}</p>
              )}
              <div class={`text-xs font-semibold ${pillarConfig.pillarColor}`}>記事を読む →</div>
            </div>
          </a>
        ))}
      </div>
    )}

    <!-- 親カテゴリへのリンク -->
    <div class="mt-8 pt-6 border-t border-slate-200 text-center">
      <a href={pillarUrl} class={`inline-block text-sm font-semibold ${pillarConfig.pillarColor} hover:underline`}>
        ← {pillarConfig.pillarLabel}の記事一覧に戻る
      </a>
    </div>

  </div>
</BaseLayout>
