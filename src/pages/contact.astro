---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="お問い合わせ"
  description="会社員の生活日記へのお問い合わせページです。ご質問・ご意見・ご要望はこちらからどうぞ。通常2〜3営業日以内にご返信いたします。"
  ctxNavMode="home-only"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "url": "https://tech-wealth-mind.com/contact/",
    "publisher": {
      "@type": "Organization",
      "name": "会社員の生活日記",
      "url": "https://tech-wealth-mind.com",
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "Customer Service",
        "url": "https://tech-wealth-mind.com/contact/"
      }
    }
  })} />

  <div class="max-w-3xl mx-auto px-4 py-12">
    <article class="bg-white rounded-lg shadow-sm p-8 md:p-12">
      <h1 class="text-3xl font-extrabold text-slate-900 mb-4 pb-4 border-b-2 border-blue-500">お問い合わせ</h1>
      <p class="text-slate-600 mb-6">ご質問・ご意見・ご要望がございましたら、以下のフォームよりお送りください。通常2〜3営業日以内にご返信いたします。</p>

      <div class="mb-8 p-4 bg-blue-50 rounded-lg border border-blue-100 text-slate-600 text-sm">
        ※ 個別の投資判断、医療・心理相談、専門的な診断・助言には対応しておりません。<br>
        ※ サイト内容に関するご意見・誤りのご指摘は歓迎いたします。
      </div>

      <!-- 送信成功メッセージ -->
      <div id="form-success" class="hidden mb-6 p-5 bg-green-50 border border-green-200 rounded-lg text-center">
        <div class="text-2xl mb-2">✅</div>
        <p class="font-bold text-green-800 mb-1">送信が完了しました！</p>
        <p class="text-green-700 text-sm">お問い合わせありがとうございます。通常2〜3営業日以内にご返信いたします。</p>
      </div>

      <!-- エラーメッセージ -->
      <div id="form-error" class="hidden mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
        <p class="text-red-700 text-sm font-semibold" id="form-error-msg">送信に失敗しました。時間をおいて再度お試しください。</p>
      </div>

      <!-- お問い合わせフォーム -->
      <form id="contact-form" novalidate>
        <div class="space-y-5">
          <!-- お名前 -->
          <div>
            <label for="name" class="block text-sm font-semibold text-slate-700 mb-1">
              お名前 <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="山田 太郎"
              class="w-full border border-slate-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent transition"
            />
          </div>

          <!-- メールアドレス -->
          <div>
            <label for="email" class="block text-sm font-semibold text-slate-700 mb-1">
              メールアドレス <span class="text-red-500">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="your@example.com"
              class="w-full border border-slate-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent transition"
            />
          </div>

          <!-- 件名 -->
          <div>
            <label for="subject" class="block text-sm font-semibold text-slate-700 mb-1">
              件名
            </label>
            <input
              type="text"
              id="subject"
              name="subject"
              placeholder="例：記事の内容について"
              class="w-full border border-slate-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent transition"
            />
          </div>

          <!-- メッセージ -->
          <div>
            <label for="message" class="block text-sm font-semibold text-slate-700 mb-1">
              メッセージ <span class="text-red-500">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="6"
              placeholder="お問い合わせ内容をご記入ください。"
              class="w-full border border-slate-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent transition resize-y"
            ></textarea>
          </div>

          <!-- 送信ボタン -->
          <div>
            <button
              type="submit"
              id="submit-btn"
              class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-lg transition-colors disabled:opacity-60 disabled:cursor-not-allowed flex items-center justify-center gap-2"
            >
              <span id="submit-label">送信する</span>
              <span id="submit-spinner" class="hidden">
                <svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
              </span>
            </button>
          </div>
        </div>
      </form>

    </article>
  </div>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const btn  = document.getElementById('submit-btn') as HTMLButtonElement;
    const label   = document.getElementById('submit-label')!;
    const spinner = document.getElementById('submit-spinner')!;
    const success = document.getElementById('form-success')!;
    const errBox  = document.getElementById('form-error')!;
    const errMsg  = document.getElementById('form-error-msg')!;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();


      const name    = (form.elements.namedItem('name') as HTMLInputElement).value.trim();
      const email   = (form.elements.namedItem('email') as HTMLInputElement).value.trim();
      const message = (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim();
      if (!name || !email || !message) {
        showError('お名前・メールアドレス・メッセージは必須項目です。');
        return;
      }

      btn.disabled = true;
      label.textContent = '送信中...';
      spinner.classList.remove('hidden');
      errBox.classList.add('hidden');

      try {
        const data = new FormData(form);
        const res  = await fetch('/api/contact', { method: 'POST', body: data });
        const json = await res.json();

        if (res.ok && json.success) {
          form.classList.add('hidden');
          success.classList.remove('hidden');
        } else {
          showError(json.error || '送信に失敗しました。時間をおいて再度お試しください。');
        }
      } catch {
        showError('送信に失敗しました。ネットワーク接続を確認してください。');
      } finally {
        btn.disabled = false;
        label.textContent = '送信する';
        spinner.classList.add('hidden');
      }
    });

    function showError(msg: string) {
      errMsg.textContent = msg;
      errBox.classList.remove('hidden');
      errBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  </script>
</BaseLayout>
