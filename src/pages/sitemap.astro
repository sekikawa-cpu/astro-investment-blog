---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(p => !p.data.draft && !p.data.noindex)
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

const PILLARS = [
  {
    key: 'ai-dx',
    label: 'AI/DX・生成AI活用',
    icon: '🤖',
    slug: 'ai-dx',
    border: 'border-purple-400',
    text: 'text-purple-600',
    categories: ['AIツール', 'AI最新情報'],
  },
  {
    key: 'shikaku',
    label: '資格・学習記録',
    icon: '📖',
    slug: 'shikaku',
    border: 'border-amber-400',
    text: 'text-amber-600',
    categories: ['資格・学習'],
  },
  {
    key: 'shigoto',
    label: '仕事術・キャリア形成',
    icon: '💼',
    slug: 'shigoto',
    border: 'border-cyan-400',
    text: 'text-cyan-600',
    categories: ['DX・業務改善', '書籍レビュー'],
  },
];
---
<BaseLayout
  title="サイトマップ"
  description="会社員の生活日記のサイトマップです。AI/DX・資格・学習・仕事術のカテゴリ別記事一覧と主要ページへのリンクをまとめています。"
  ctxNavMode="home-only"
>
  <div class="max-w-3xl mx-auto px-4 py-10">

    <h1 class="text-2xl md:text-3xl font-extrabold text-slate-900 mb-2">🗺️ サイトマップ</h1>
    <p class="text-slate-500 text-sm mb-8">サイト内のページ・記事一覧です。</p>

    <!-- 主要ページ -->
    <section class="bg-white rounded-xl border border-slate-200 shadow-sm p-6 mb-8">
      <h2 class="text-base font-bold text-slate-700 mb-4 pb-2 border-b border-slate-100">主要ページ</h2>
      <ul class="grid grid-cols-2 sm:grid-cols-3 gap-2">
        {[
          { href: '/',              label: '🏠 トップページ' },
          { href: '/for-beginners/', label: '✨ 初めての方へ' },
          { href: '/about/',        label: '👤 プロフィール' },
          { href: '/contact/',      label: '✉️ お問い合わせ' },
          { href: '/privacy/',      label: '🔒 プライバシーポリシー' },
          { href: '/disclaimer/',   label: '⚠️ 免責事項' },
          { href: '/search/',       label: '🔍 記事検索' },
        ].map(({ href, label }) => (
          <li>
            <a href={href} class="block text-sm text-blue-600 hover:underline hover:text-blue-800 py-1 px-2 rounded hover:bg-blue-50 transition-colors">
              {label}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <!-- カテゴリ別記事 -->
    {PILLARS.map(({ label, icon, slug, border, text, categories }) => {
      const pillarPosts = posts.filter(p => categories.includes(p.data.category ?? ''));
      return (
        <section class="bg-white rounded-xl border border-slate-200 shadow-sm p-6 mb-6">
          <h2 class={`text-base font-bold mb-1 flex items-center gap-2 ${text}`}>
            <span>{icon}</span>
            <span>{label}</span>
            <span class="text-slate-400 font-normal text-sm ml-auto">{pillarPosts.length}件</span>
          </h2>
          <a href={`/category/${slug}/`}
            class={`inline-block text-xs font-semibold ${text} hover:underline mb-4`}>
            カテゴリページを見る →
          </a>
          <ul class={`border-l-2 ${border} pl-4 space-y-1`}>
            {pillarPosts.map(post => (
              <li>
                <a href={`/blog/${post.slug}/`}
                  class="text-sm text-slate-700 hover:text-blue-600 hover:underline transition-colors leading-snug block py-0.5">
                  {post.data.title}
                </a>
              </li>
            ))}
          </ul>
        </section>
      );
    })}

  </div>

</BaseLayout>
